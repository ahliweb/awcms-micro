---
/**
 * Public self-registration page (Issue: self-registration). Submits an
 * admin-approval-gated request via `POST /api/v1/auth/register`
 * ({ displayName, loginIdentifier, password } + tenant header).
 *
 * Gated by `AUTH_SELF_REGISTRATION_ENABLED`: when off, the route redirects to
 * /login so the feature is genuinely absent (the endpoint 404s too).
 *
 * Anti-enumeration (mirrors the endpoint): a successful submit ALWAYS shows
 * the same neutral "awaiting approval" notice — the visitor never learns
 * whether the identifier was already taken. Shares the `src/styles/auth.css`
 * surface + theme/i18n/Turnstile wiring with the other auth screens.
 */
import "../styles/tokens.css";
import "../styles/auth.css";
import { createTranslator } from "../lib/i18n/translate";
import { buildClientErrorMessages } from "../lib/i18n/error-messages";
import { isTurnstileRequired } from "../lib/security/turnstile";
import { isSelfRegistrationEnabled } from "../lib/auth/self-registration-config";
import { THEME_INIT_SCRIPT_BODY } from "../lib/security/theme-init-script";
import {
  isLoginTenantPickerEnabled,
  listActiveTenantsForLogin,
  type LoginTenantOption
} from "../lib/auth/login-tenant-picker";

if (!isSelfRegistrationEnabled()) {
  return Astro.redirect("/login", 302);
}

const locale = Astro.locals.locale;
const t = await createTranslator(locale);
const turnstileActive = isTurnstileRequired();
const turnstileSiteKey = turnstileActive
  ? process.env.TURNSTILE_SITE_KEY
  : null;

const tenantPickerActive = isLoginTenantPickerEnabled();
const tenantOptions: LoginTenantOption[] = tenantPickerActive
  ? await listActiveTenantsForLogin()
  : [];
const singleTenant =
  tenantPickerActive && tenantOptions.length === 1 ? tenantOptions[0]! : null;
const tenantSelect = tenantPickerActive && tenantOptions.length >= 2;
const tenantManual = !tenantPickerActive || tenantOptions.length === 0;

const clientStrings = {
  genericError: t("auth.register.generic_error"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  notice: t("auth.register.notice"),
  mismatch: t("auth.register.mismatch"),
  tooShort: t("auth.reset.too_short"),
  passwordShow: t("auth.password_show"),
  passwordHide: t("auth.password_hide"),
  passwordShowAria: t("auth.password_show_aria"),
  passwordHideAria: t("auth.password_hide_aria"),
  errorMessages: buildClientErrorMessages(t)
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{t("auth.register.page_title")}</title>
    <script is:inline set:html={THEME_INIT_SCRIPT_BODY} />
  </head>
  <body class="auth-body">
    <main class="auth">
      <div class="auth-card">
        <div class="auth-head">
          <a href="/" class="auth-brand">
            <span class="auth-mark" aria-hidden="true">A</span>
            <span class="auth-wordmark">AWCMS-Micro</span>
          </a>
          <h1 class="auth-title">{t("auth.register.heading")}</h1>
          <p class="auth-subtitle">{t("auth.register.subtitle")}</p>
        </div>

        <form id="register-form" class="auth-form" novalidate>
          <p id="register-error" class="auth-error" role="alert" hidden></p>
          <p id="register-notice" class="auth-notice" role="status" hidden></p>

          {
            singleTenant && (
              <div class="auth-tenant-context">
                <span class="auth-tenant-context-label">
                  {t("auth.login.tenant_context_label")}
                </span>
                <span class="auth-tenant-context-name">
                  {singleTenant.name}
                </span>
                <input
                  id="tenant-id"
                  name="tenantId"
                  type="hidden"
                  value={singleTenant.id}
                />
              </div>
            )
          }

          {
            tenantSelect && (
              <div class="auth-field">
                <label for="tenant-id">{t("auth.login.tenant_label")}</label>
                <div class="auth-select">
                  <select id="tenant-id" name="tenantId" required>
                    {tenantOptions.map((tenant) => (
                      <option value={tenant.id}>{tenant.name}</option>
                    ))}
                  </select>
                </div>
              </div>
            )
          }

          {
            tenantManual && (
              <div class="auth-field">
                <label for="tenant-id">{t("auth.login.tenant_id_label")}</label>
                <input
                  id="tenant-id"
                  name="tenantId"
                  type="text"
                  required
                  autocomplete="off"
                  spellcheck={false}
                />
              </div>
            )
          }

          <div class="auth-field">
            <label for="display-name">{t("auth.register.name_label")}</label>
            <input
              id="display-name"
              name="displayName"
              type="text"
              required
              autocomplete="name"
              maxlength="120"
            />
          </div>

          <div class="auth-field">
            <label for="login-identifier">
              {t("auth.register.identifier_label")}
            </label>
            <input
              id="login-identifier"
              name="loginIdentifier"
              type="email"
              required
              autocomplete="email"
              spellcheck={false}
              maxlength="320"
            />
          </div>

          <div class="auth-field">
            <label for="password">{t("auth.register.password_label")}</label>
            <div class="auth-password">
              <input
                id="password"
                name="password"
                type="password"
                required
                autocomplete="new-password"
                minlength="8"
              />
              <button
                type="button"
                id="password-toggle"
                class="auth-password-toggle"
                aria-pressed="false"
                aria-controls="password"
                aria-label={t("auth.password_show_aria")}
              >
                <span class="auth-password-toggle-label">
                  {t("auth.password_show")}
                </span>
              </button>
            </div>
            <p class="auth-hint">{t("auth.reset.password_hint")}</p>
          </div>

          <div class="auth-field">
            <label for="confirm-password">
              {t("auth.register.confirm_label")}
            </label>
            <input
              id="confirm-password"
              name="confirmPassword"
              type="password"
              required
              autocomplete="new-password"
            />
          </div>

          {
            turnstileActive && turnstileSiteKey && (
              <div
                class="cf-turnstile auth-turnstile"
                data-sitekey={turnstileSiteKey}
              />
            )
          }

          <button type="submit" id="register-submit" class="auth-submit">
            {t("auth.register.submit")}
          </button>
        </form>

        <nav class="auth-links" aria-label={t("auth.nav_label")}>
          <a href="/login">{t("auth.back_to_login")}</a>
        </nav>
      </div>
    </main>

    {
      turnstileActive && turnstileSiteKey && (
        <script
          src="https://challenges.cloudflare.com/turnstile/v0/api.js"
          async
          defer
        />
      )
    }

    <script
      type="application/json"
      id="i18n-strings"
      set:html={JSON.stringify(clientStrings)}
    />

    <script>
      import {
        lockElement,
        readClientStrings
      } from "../lib/ui/admin-form-client";
      import { wirePasswordToggle } from "../lib/ui/password-toggle";

      interface RegisterStrings {
        genericError: string;
        networkError: string;
        pleaseWait: string;
        notice: string;
        mismatch: string;
        tooShort: string;
        passwordShow: string;
        passwordHide: string;
        passwordShowAria: string;
        passwordHideAria: string;
        errorMessages?: Record<string, string>;
      }

      const form = document.getElementById(
        "register-form"
      ) as HTMLFormElement | null;
      const errorBox = document.getElementById("register-error");
      const noticeBox = document.getElementById("register-notice");
      const submitButton = document.getElementById(
        "register-submit"
      ) as HTMLButtonElement | null;
      const strings = readClientStrings<RegisterStrings>();

      wirePasswordToggle("password", "password-toggle", strings);

      function reveal(el: HTMLElement | null, message: string): void {
        if (!el) return;
        el.textContent = message;
        el.hidden = false;
        el.classList.remove("auth-banner--enter");
        void el.offsetWidth;
        el.classList.add("auth-banner--enter");
      }

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!submitButton || submitButton.disabled) return;
        if (errorBox) errorBox.hidden = true;

        const formData = new FormData(form);
        const tenantId = String(formData.get("tenantId") ?? "").trim();
        const displayName = String(formData.get("displayName") ?? "").trim();
        const loginIdentifier = String(
          formData.get("loginIdentifier") ?? ""
        ).trim();
        const password = String(formData.get("password") ?? "");
        const confirmPassword = String(formData.get("confirmPassword") ?? "");
        const turnstileToken = formData.get("cf-turnstile-response");

        // Client-side guards (the server re-validates; UX only).
        if (password.length < 8) {
          reveal(errorBox, strings.tooShort);
          return;
        }
        if (password !== confirmPassword) {
          reveal(errorBox, strings.mismatch);
          return;
        }

        const unlock = lockElement(submitButton, strings.pleaseWait);

        try {
          const response = await fetch("/api/v1/auth/register", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-AWCMS-Micro-Tenant-ID": tenantId
            },
            credentials: "same-origin",
            body: JSON.stringify({
              displayName,
              loginIdentifier,
              password,
              ...(turnstileToken ? { turnstileToken } : {})
            })
          });

          const payload = await response.json().catch(() => null);

          if (!response.ok || !payload || payload.success !== true) {
            const code = payload?.error?.code as string | undefined;
            const localized = code ? strings.errorMessages?.[code] : null;
            reveal(errorBox, localized ?? strings.genericError);
            unlock();
            return;
          }

          // Generic success (the account may or may not be new). Hide the form
          // and show the neutral "awaiting approval" notice.
          form.hidden = true;
          reveal(noticeBox, strings.notice);
        } catch {
          reveal(errorBox, strings.networkError);
          unlock();
        }
      });
    </script>
  </body>
</html>
