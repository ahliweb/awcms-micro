---
/**
 * Per-tenant sidebar menu management screen (feat/sidebar-menu-management).
 *
 * Lets an admin flexibly arrange the admin sidebar — grouped type -> sub-type
 * (module) -> items: reorder types/modules/items, show/hide, rename labels
 * (override), move an item to a different type, add a custom type, and reset to
 * the code default. Config is per-tenant (RLS FORCE on the two override tables).
 *
 * Gating (same "each section gated on its own permission" convention
 * `admin/business-scope.astro`/`admin/security.astro` use — hiding a control is
 * a UX nicety; the endpoints' own `authorizeInTransaction` guard is the real
 * enforcement): the whole page needs `module_management.navigation.read`; the
 * save/reset controls need `module_management.navigation.configure`.
 *
 * SSR reads `fetchSidebarConfigForAdmin` directly inside this page's own
 * `withTenant` transaction (same pattern as the reference pages above). All
 * mutations go through the real `/api/v1/navigation/sidebar-config` endpoints
 * via `submitJson` — every write still runs through ABAC + idempotency + audit.
 *
 * The editor is a vanilla island (no drag-drop framework): up/down reorder,
 * show/hide toggles, label-override inputs, a move-to-type select, add-custom-
 * type, and a reset button (ConfirmDialog). On save the client serializes the
 * current DOM tree into the `{ types, items }` payload — DOM order is the
 * source of truth for positions and a section's `data-type-key` is the source
 * of truth for an item's type placement.
 */
import AdminLayout from "../../layouts/AdminLayout.astro";
import StateNotice from "../../components/ui/StateNotice.astro";
import ActionBanner from "../../components/ui/ActionBanner.astro";
import ConfirmDialog from "../../components/ui/ConfirmDialog.astro";
import { getDatabaseClient } from "../../lib/database/client";
import { withTenant } from "../../lib/database/tenant-context";
import { permissionKey } from "../../modules/identity-access/domain/access-control";
import {
  fetchSidebarConfigForAdmin,
  type AdminSidebarConfig
} from "../../modules/module-management/application/sidebar-menu-config";
import { CORE_MODULE_KEY } from "../../modules/module-management/domain/sidebar-menu";
import { createTranslator } from "../../lib/i18n/translate";
import { logAdminPageError } from "../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/sidebar-menu.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("module_management", "navigation", "read")
);
const CAN_CONFIGURE = context.permissions.has(
  permissionKey("module_management", "navigation", "configure")
);

let config: AdminSidebarConfig | null = null;
let loadError = false;

if (CAN_READ) {
  try {
    config = await withTenant(
      getDatabaseClient(),
      context.tenantId,
      (tx) => fetchSidebarConfigForAdmin(tx, context.tenantId),
      { unavailableBehavior: "throw" }
    );
  } catch (error) {
    loadError = true;
    logAdminPageError("admin/sidebar-menu", error);
  }
}

// Resolve a type/item label for display: override wins, then i18n key, then the
// raw key/path fallback.
function resolveLabel(
  labelKey: string | undefined,
  labelOverride: string | null,
  fallback: string
): string {
  if (labelOverride && labelOverride.length > 0) return labelOverride;
  if (labelKey) return t(labelKey);
  return fallback;
}

const availableTypeOptions = (config?.availableTypeKeys ?? []).map((type) => ({
  typeKey: type.typeKey,
  label: type.labelKey ? t(type.labelKey) : type.typeKey
}));

const clientStrings = {
  saveSuccess: t("admin.sidebar_menu.save_success"),
  resetSuccess: t("admin.sidebar_menu.reset_success"),
  resetConfirmTitle: t("admin.sidebar_menu.reset_confirm_title"),
  resetConfirmBody: t("admin.sidebar_menu.reset_confirm_body"),
  resetConfirmAccept: t("admin.sidebar_menu.reset_confirm_accept"),
  resetConfirmCancel: t("admin.sidebar_menu.reset_confirm_cancel"),
  invalidTypeKey: t("admin.sidebar_menu.invalid_type_key"),
  hiddenLabel: t("admin.sidebar_menu.hidden_label"),
  moveUp: t("admin.sidebar_menu.move_up"),
  moveDown: t("admin.sidebar_menu.move_down"),
  moveToType: t("admin.sidebar_menu.move_to_type"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};
---

<AdminLayout title={t("admin.sidebar_menu.title")}>
  <h1>{t("admin.sidebar_menu.title")}</h1>
  <p>{t("admin.sidebar_menu.subtitle")}</p>

  <ActionBanner id="action-banner" />

  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.sidebar_menu.access_denied_title")}
        body={t("admin.sidebar_menu.access_denied_body")}
      />
    )
  }

  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }

  {
    CAN_READ && config && (
      <div
        id="sidebar-editor"
        data-can-configure={CAN_CONFIGURE ? "true" : "false"}
      >
        <h2>{t("admin.sidebar_menu.types_heading")}</h2>

        <div class="sm-types" id="sm-types">
          {config.types.map((type) => (
            <section
              class="sm-type"
              data-type-key={type.typeKey}
              data-custom={type.isCustom ? "true" : "false"}
            >
              <div class="sm-type-head">
                <input
                  class="sm-type-label"
                  data-type-label
                  type="text"
                  value={type.labelOverride ?? ""}
                  placeholder={type.labelKey ? t(type.labelKey) : type.typeKey}
                  aria-label={t("admin.sidebar_menu.type_label_aria")}
                  disabled={!CAN_CONFIGURE}
                  maxlength="120"
                />
                <label class="sm-inline-check">
                  <input
                    type="checkbox"
                    data-type-hidden
                    checked={type.hidden}
                    disabled={!CAN_CONFIGURE}
                  />
                  {t("admin.sidebar_menu.hidden_label")}
                </label>
                {CAN_CONFIGURE && (
                  <span class="sm-reorder">
                    <button
                      type="button"
                      class="sm-btn"
                      data-type-up
                      aria-label={t("admin.sidebar_menu.move_up")}
                    >
                      ↑
                    </button>
                    <button
                      type="button"
                      class="sm-btn"
                      data-type-down
                      aria-label={t("admin.sidebar_menu.move_down")}
                    >
                      ↓
                    </button>
                  </span>
                )}
              </div>

              <div class="sm-modules" data-modules>
                {type.modules.map((group) => (
                  <div class="sm-module" data-module-key={group.moduleKey}>
                    {group.moduleKey !== CORE_MODULE_KEY && (
                      <div class="sm-module-head">
                        <span class="sm-module-label">{group.moduleName}</span>
                        {CAN_CONFIGURE && (
                          <span class="sm-reorder">
                            <button
                              type="button"
                              class="sm-btn"
                              data-module-up
                              aria-label={t("admin.sidebar_menu.move_up")}
                            >
                              ↑
                            </button>
                            <button
                              type="button"
                              class="sm-btn"
                              data-module-down
                              aria-label={t("admin.sidebar_menu.move_down")}
                            >
                              ↓
                            </button>
                          </span>
                        )}
                      </div>
                    )}
                    <div class="sm-items" data-items>
                      {group.items.map((item) => (
                        <div
                          class="sm-item"
                          data-entry-key={item.entryKey}
                          data-module-key={group.moduleKey}
                          data-hidden={item.hidden ? "true" : "false"}
                        >
                          <span class="sm-item-name">
                            {resolveLabel(
                              item.labelKey,
                              item.labelOverride,
                              item.path
                            )}
                          </span>
                          <input
                            class="sm-item-label"
                            data-item-label
                            type="text"
                            value={item.labelOverride ?? ""}
                            placeholder={t(item.labelKey)}
                            aria-label={t("admin.sidebar_menu.item_label_aria")}
                            disabled={!CAN_CONFIGURE}
                            maxlength="120"
                          />
                          <label class="sm-inline-check">
                            <input
                              type="checkbox"
                              data-item-hidden
                              checked={item.hidden}
                              disabled={!CAN_CONFIGURE}
                            />
                            {t("admin.sidebar_menu.hidden_label")}
                          </label>
                          <label class="sm-move">
                            <span class="sm-visually-hidden">
                              {t("admin.sidebar_menu.move_to_type")}
                            </span>
                            <select data-item-move disabled={!CAN_CONFIGURE}>
                              {availableTypeOptions.map((opt) => (
                                <option
                                  value={opt.typeKey}
                                  selected={opt.typeKey === item.typeKey}
                                >
                                  {opt.label}
                                </option>
                              ))}
                            </select>
                          </label>
                          {CAN_CONFIGURE && (
                            <span class="sm-reorder">
                              <button
                                type="button"
                                class="sm-btn"
                                data-item-up
                                aria-label={t("admin.sidebar_menu.move_up")}
                              >
                                ↑
                              </button>
                              <button
                                type="button"
                                class="sm-btn"
                                data-item-down
                                aria-label={t("admin.sidebar_menu.move_down")}
                              >
                                ↓
                              </button>
                            </span>
                          )}
                          {(item.requiredPermission ||
                            item.requiredPermissionPrefix) && (
                            <span class="sm-gated">
                              {t("admin.sidebar_menu.permission_gated_note")}
                            </span>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </section>
          ))}
        </div>

        {CAN_CONFIGURE && (
          <section class="sm-add-type">
            <h3>{t("admin.sidebar_menu.add_type_heading")}</h3>
            <div class="sm-add-type-row">
              <label class="sm-field">
                <span>{t("admin.sidebar_menu.add_type_key_label")}</span>
                <input id="sm-add-type-key" type="text" maxlength="64" />
              </label>
              <label class="sm-field">
                <span>{t("admin.sidebar_menu.add_type_label_label")}</span>
                <input id="sm-add-type-label" type="text" maxlength="120" />
              </label>
              <button type="button" id="sm-add-type-button">
                {t("admin.sidebar_menu.add_type_button")}
              </button>
            </div>
          </section>
        )}

        {CAN_CONFIGURE && (
          <div class="sm-actions">
            <button type="button" id="sm-save">
              {t("admin.sidebar_menu.save_button")}
            </button>
            <button type="button" id="sm-reset" class="sm-danger">
              {t("admin.sidebar_menu.reset_button")}
            </button>
          </div>
        )}
      </div>
    )
  }

  <ConfirmDialog
    id="sm-confirm-dialog"
    confirmLabel={t("admin.sidebar_menu.reset_confirm_accept")}
    cancelLabel={t("admin.sidebar_menu.reset_confirm_cancel")}
  />

  <script
    type="application/json"
    id="i18n-strings"
    set:html={JSON.stringify(clientStrings)}
  />

  <script>
    import {
      lockElement,
      newIdempotencyKey,
      readClientStrings,
      showBanner,
      submitJson
    } from "../../lib/ui/admin-form-client";
    import { openConfirmDialog } from "../../lib/ui/confirm-dialog-client";

    const strings = readClientStrings<{
      saveSuccess: string;
      resetSuccess: string;
      resetConfirmTitle: string;
      resetConfirmBody: string;
      resetConfirmAccept: string;
      resetConfirmCancel: string;
      invalidTypeKey: string;
      hiddenLabel: string;
      moveUp: string;
      moveDown: string;
      moveToType: string;
      networkError: string;
      pleaseWait: string;
      errorMessages: Record<string, string>;
    }>();

    const editor = document.getElementById("sidebar-editor");
    const canConfigure = editor?.dataset.canConfigure === "true";
    const typesContainer = document.getElementById("sm-types");

    const TYPE_KEY_RE = /^[a-z0-9_]+$/;

    function reloadAfterDelay(): void {
      setTimeout(() => window.location.reload(), 600);
    }

    // ---- Reorder helpers (swap an element with its previous/next sibling) ----
    function swapWithPrevious(el: Element | null, selector: string): void {
      if (!el) return;
      const prev = el.previousElementSibling;
      if (prev && prev.matches(selector)) {
        el.parentElement?.insertBefore(el, prev);
      }
    }
    function swapWithNext(el: Element | null, selector: string): void {
      if (!el) return;
      const next = el.nextElementSibling;
      if (next && next.matches(selector)) {
        el.parentElement?.insertBefore(next, el);
      }
    }

    function closest<T extends Element>(
      from: Element,
      selector: string
    ): T | null {
      return from.closest(selector) as T | null;
    }

    // ---- Move an item into a different type section --------------------------
    function moveItemToType(item: HTMLElement, targetTypeKey: string): void {
      const targetSection = typesContainer?.querySelector<HTMLElement>(
        `.sm-type[data-type-key="${CSS.escape(targetTypeKey)}"]`
      );
      if (!targetSection) return;
      const modulesHost =
        targetSection.querySelector<HTMLElement>("[data-modules]");
      if (!modulesHost) return;

      const moduleKey = item.dataset.moduleKey ?? "";
      let moduleDiv = modulesHost.querySelector<HTMLElement>(
        `.sm-module[data-module-key="${CSS.escape(moduleKey)}"]`
      );
      if (!moduleDiv) {
        moduleDiv = document.createElement("div");
        moduleDiv.className = "sm-module";
        moduleDiv.dataset.moduleKey = moduleKey;
        const itemsHost = document.createElement("div");
        itemsHost.setAttribute("data-items", "");
        itemsHost.className = "sm-items";
        moduleDiv.appendChild(itemsHost);
        modulesHost.appendChild(moduleDiv);
      }
      moduleDiv.querySelector<HTMLElement>("[data-items]")?.appendChild(item);
    }

    // ---- Event delegation for all reorder/move controls ---------------------
    editor?.addEventListener("click", (event) => {
      const target = event.target as HTMLElement;
      if (!(target instanceof HTMLElement)) return;

      if (target.hasAttribute("data-type-up")) {
        swapWithPrevious(closest(target, ".sm-type"), ".sm-type");
      } else if (target.hasAttribute("data-type-down")) {
        swapWithNext(closest(target, ".sm-type"), ".sm-type");
      } else if (target.hasAttribute("data-module-up")) {
        swapWithPrevious(closest(target, ".sm-module"), ".sm-module");
      } else if (target.hasAttribute("data-module-down")) {
        swapWithNext(closest(target, ".sm-module"), ".sm-module");
      } else if (target.hasAttribute("data-item-up")) {
        swapWithPrevious(closest(target, ".sm-item"), ".sm-item");
      } else if (target.hasAttribute("data-item-down")) {
        swapWithNext(closest(target, ".sm-item"), ".sm-item");
      }
    });

    editor?.addEventListener("change", (event) => {
      const target = event.target as HTMLElement;
      if (
        target instanceof HTMLSelectElement &&
        target.hasAttribute("data-item-move")
      ) {
        const item = closest<HTMLElement>(target, ".sm-item");
        if (item) moveItemToType(item, target.value);
      }
    });

    // ---- Add a custom type --------------------------------------------------
    function addTypeOption(typeKey: string, label: string): void {
      document
        .querySelectorAll<HTMLSelectElement>("[data-item-move]")
        .forEach((select) => {
          if (!select.querySelector(`option[value="${CSS.escape(typeKey)}"]`)) {
            const opt = document.createElement("option");
            opt.value = typeKey;
            opt.textContent = label;
            select.appendChild(opt);
          }
        });
    }

    document
      .getElementById("sm-add-type-button")
      ?.addEventListener("click", () => {
        const keyInput = document.getElementById(
          "sm-add-type-key"
        ) as HTMLInputElement | null;
        const labelInput = document.getElementById(
          "sm-add-type-label"
        ) as HTMLInputElement | null;
        const typeKey = (keyInput?.value ?? "").trim();
        const label = (labelInput?.value ?? "").trim();

        if (!TYPE_KEY_RE.test(typeKey) || typeKey.length > 64) {
          showBanner("action-banner", strings.invalidTypeKey, "error");
          return;
        }
        if (
          typesContainer?.querySelector(
            `.sm-type[data-type-key="${CSS.escape(typeKey)}"]`
          )
        ) {
          showBanner("action-banner", strings.invalidTypeKey, "error");
          return;
        }

        const section = document.createElement("section");
        section.className = "sm-type";
        section.dataset.typeKey = typeKey;
        section.dataset.custom = "true";

        const head = document.createElement("div");
        head.className = "sm-type-head";
        const labelField = document.createElement("input");
        labelField.className = "sm-type-label";
        labelField.setAttribute("data-type-label", "");
        labelField.type = "text";
        labelField.value = label;
        labelField.maxLength = 120;
        head.appendChild(labelField);

        const hiddenLabel = document.createElement("label");
        hiddenLabel.className = "sm-inline-check";
        const hiddenCheck = document.createElement("input");
        hiddenCheck.type = "checkbox";
        hiddenCheck.setAttribute("data-type-hidden", "");
        hiddenLabel.appendChild(hiddenCheck);
        hiddenLabel.appendChild(
          document.createTextNode(" " + strings.hiddenLabel)
        );
        head.appendChild(hiddenLabel);

        const reorder = document.createElement("span");
        reorder.className = "sm-reorder";
        const up = document.createElement("button");
        up.type = "button";
        up.className = "sm-btn";
        up.setAttribute("data-type-up", "");
        up.setAttribute("aria-label", strings.moveUp);
        up.textContent = "↑";
        const down = document.createElement("button");
        down.type = "button";
        down.className = "sm-btn";
        down.setAttribute("data-type-down", "");
        down.setAttribute("aria-label", strings.moveDown);
        down.textContent = "↓";
        reorder.appendChild(up);
        reorder.appendChild(down);
        head.appendChild(reorder);

        section.appendChild(head);
        const modulesHost = document.createElement("div");
        modulesHost.className = "sm-modules";
        modulesHost.setAttribute("data-modules", "");
        section.appendChild(modulesHost);

        typesContainer?.appendChild(section);
        addTypeOption(typeKey, label.length > 0 ? label : typeKey);

        if (keyInput) keyInput.value = "";
        if (labelInput) labelInput.value = "";
      });

    // ---- Serialize the DOM tree into the save payload -----------------------
    function serialize(): {
      types: {
        typeKey: string;
        labelOverride: string | null;
        position: number;
        hidden: boolean;
      }[];
      items: {
        entryKey: string;
        typeKey: string;
        position: number;
        labelOverride: string | null;
        hidden: boolean;
      }[];
    } {
      const types: ReturnType<typeof serialize>["types"] = [];
      const items: ReturnType<typeof serialize>["items"] = [];

      const sections = Array.from(
        typesContainer?.querySelectorAll<HTMLElement>(".sm-type") ?? []
      );
      sections.forEach((section, typeIndex) => {
        const typeKey = section.dataset.typeKey ?? "";
        const labelInput =
          section.querySelector<HTMLInputElement>("[data-type-label]");
        const hiddenInput =
          section.querySelector<HTMLInputElement>("[data-type-hidden]");
        const labelValue = (labelInput?.value ?? "").trim();
        types.push({
          typeKey,
          labelOverride: labelValue.length > 0 ? labelValue : null,
          position: typeIndex,
          hidden: hiddenInput?.checked ?? false
        });

        // Items in DOM order within the section (across modules) — module order
        // therefore emerges from the position counter below.
        const itemEls = Array.from(
          section.querySelectorAll<HTMLElement>(".sm-item")
        );
        itemEls.forEach((itemEl, itemIndex) => {
          const entryKey = itemEl.dataset.entryKey ?? "";
          const itemLabel =
            itemEl.querySelector<HTMLInputElement>("[data-item-label]");
          const itemHidden =
            itemEl.querySelector<HTMLInputElement>("[data-item-hidden]");
          const itemLabelValue = (itemLabel?.value ?? "").trim();
          items.push({
            entryKey,
            typeKey,
            position: itemIndex,
            labelOverride: itemLabelValue.length > 0 ? itemLabelValue : null,
            hidden: itemHidden?.checked ?? false
          });
        });
      });

      return { types, items };
    }

    // ---- Save ---------------------------------------------------------------
    document.getElementById("sm-save")?.addEventListener("click", async () => {
      if (!canConfigure) return;
      const button = document.getElementById("sm-save") as HTMLButtonElement;
      if (button.disabled) return;
      const unlock = lockElement(button, strings.pleaseWait);
      try {
        const result = await submitJson(
          "/api/v1/navigation/sidebar-config",
          "PUT",
          serialize(),
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );
        showBanner(
          "action-banner",
          result.ok ? strings.saveSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock();
      }
    });

    // ---- Reset --------------------------------------------------------------
    document.getElementById("sm-reset")?.addEventListener("click", async () => {
      if (!canConfigure) return;
      const button = document.getElementById("sm-reset") as HTMLButtonElement;
      if (button.disabled) return;

      const confirmResult = await openConfirmDialog("sm-confirm-dialog", {
        title: strings.resetConfirmTitle,
        body: strings.resetConfirmBody,
        confirmLabel: strings.resetConfirmAccept,
        cancelLabel: strings.resetConfirmCancel
      });
      if (!confirmResult.confirmed) return;

      const unlock = lockElement(button, strings.pleaseWait);
      try {
        const result = await submitJson(
          "/api/v1/navigation/sidebar-config/reset",
          "POST",
          {},
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );
        showBanner(
          "action-banner",
          result.ok ? strings.resetSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock();
      }
    });
  </script>

  <style>
    .sm-types {
      display: flex;
      flex-direction: column;
      gap: var(--sp-4);
      margin-bottom: var(--sp-4);
    }

    .sm-type {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--sp-3);
      background: var(--color-surface);
    }

    .sm-type-head {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--sp-2);
      margin-bottom: var(--sp-2);
    }

    .sm-type-label {
      flex: 1 1 200px;
      min-height: 44px;
      padding: var(--sp-1) var(--sp-2);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      background: var(--color-surface);
      color: var(--color-text);
      font-size: var(--fs-md);
      font-weight: 600;
    }

    .sm-modules {
      display: flex;
      flex-direction: column;
      gap: var(--sp-3);
    }

    .sm-module {
      border-left: 2px solid var(--color-border);
      padding-left: var(--sp-3);
    }

    .sm-module-head {
      display: flex;
      align-items: center;
      gap: var(--sp-2);
      margin-bottom: var(--sp-1);
    }

    .sm-module-label {
      font-size: var(--fs-sm);
      font-weight: 600;
      color: var(--color-text-muted);
    }

    .sm-items {
      display: flex;
      flex-direction: column;
      gap: var(--sp-2);
    }

    .sm-item {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--sp-2);
      padding: var(--sp-2);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      background: var(--color-surface-2);
    }

    .sm-item[data-hidden="true"] {
      opacity: 0.6;
    }

    .sm-item-name {
      flex: 1 1 160px;
      font-weight: 600;
      font-size: var(--fs-sm);
    }

    .sm-item-label,
    .sm-move select {
      min-height: 44px;
      padding: var(--sp-1) var(--sp-2);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      background: var(--color-surface);
      color: var(--color-text);
      font-size: var(--fs-sm);
