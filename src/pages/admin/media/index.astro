---
/**
 * Media library browser (ADR-0026 step 5d) — the first UI this repo has ever had
 * for the media registry `media_library` owns.
 *
 * ## Why this exists
 *
 * Steps 5/5a gave `media_library` a complete HTTP surface (list, detail, attach,
 * detach, delete, restore, purge — all nine `media.*` permissions now enforced),
 * but every one of them was reachable only with `curl`. Two consequences this
 * page closes:
 *
 *   * `admin/news-portal/ad-placements.astro`'s own header records the gap
 *     plainly — "`mediaObjectId` is a manually-typed UUID — no media picker UI
 *     exists anywhere in this repo yet". An editor had no way to SEE the id of
 *     the image they uploaded. This page shows each object's id next to its
 *     thumbnail, which is what makes that field fillable without a database
 *     query. It is deliberately not a picker widget: a picker is a component
 *     embedded in those forms, a separate and larger job.
 *   * A soft-deleted object was, in practice, invisible and unrecoverable
 *     through the UI even though `restore` has existed since Issue #633.
 *
 * ## Reads go through the module, mutations go through the API
 *
 * The SSR read below calls `listNewsMediaObjects` inside `withTenant` after
 * checking `context.permissions`, which is what every admin page here does
 * (`news-portal/ad-placements.astro`, `blog/posts/index.astro`). RLS is the
 * second line of defence, the permission check the first.
 *
 * The mutations do NOT do that — they `fetch` the real guarded endpoints from
 * the client. Not for symmetry: attach/detach/restore/purge each require an
 * `Idempotency-Key`, audit-log their actor, and answer 404-vs-409 through
 * `media-object-lifecycle-failure.ts`. Reimplementing any of that in page
 * frontmatter would fork the rules rather than reuse them.
 *
 * ## Which actions appear
 *
 * A button is rendered only when BOTH the permission is held and the object's
 * status admits the transition (`verified` -> attach, `attached` -> detach,
 * soft-deleted -> restore/purge). Hiding an inapplicable button is a UX
 * courtesy, never the enforcement: the server rejects the same call regardless,
 * per the navigation-visibility-is-not-authorization convention
 * `identity-access/module.ts` documents. The status filter defaults to showing
 * everything live and nothing deleted, matching `GET /api/v1/media/objects`'s
 * own default so the page and the API never disagree about what "the media
 * library" means.
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../../lib/database/client";
import { withTenant } from "../../../lib/database/tenant-context";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import {
  isNewsMediaObjectStatus,
  isNewsMediaOwnerResourceType,
  listNewsMediaObjects,
  NEWS_MEDIA_OBJECT_STATUSES,
  NEWS_MEDIA_OWNER_RESOURCE_TYPES,
  type NewsMediaObjectStatus,
  type NewsMediaOwnerResourceType
} from "../../../modules/media-library/application/media-object-directory";
import { createTranslator } from "../../../lib/i18n/translate";
import { logAdminPageError } from "../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/media/index.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("media_library", "media", "read")
);
const CAN_ATTACH = context.permissions.has(
  permissionKey("media_library", "media", "attach")
);
const CAN_DETACH = context.permissions.has(
  permissionKey("media_library", "media", "detach")
);
const CAN_DELETE = context.permissions.has(
  permissionKey("media_library", "media", "delete")
);
const CAN_RESTORE = context.permissions.has(
  permissionKey("media_library", "media", "restore")
);
const CAN_PURGE = context.permissions.has(
  permissionKey("media_library", "media", "purge")
);

// An unknown filter value is dropped rather than 400'd: this is a URL a person
// can edit by hand, and the honest recovery from a typo is "show the unfiltered
// list", not an error page. The API route validates strictly instead, because a
// silently-empty list there would read to a programmatic caller as "you have no
// media" — see its own header.
const statusParam = Astro.url.searchParams.get("status");
const selectedStatus: NewsMediaObjectStatus | undefined =
  statusParam && isNewsMediaObjectStatus(statusParam) ? statusParam : undefined;

const ownerTypeParam = Astro.url.searchParams.get("ownerResourceType");
const selectedOwnerType: NewsMediaOwnerResourceType | undefined =
  ownerTypeParam && isNewsMediaOwnerResourceType(ownerTypeParam)
    ? ownerTypeParam
    : undefined;

const includeDeleted = Astro.url.searchParams.get("includeDeleted") === "true";

const clientStrings = {
  attachSuccess: t("admin.media.attach_success"),
  detachSuccess: t("admin.media.detach_success"),
  deleteSuccess: t("admin.media.delete_success"),
  restoreSuccess: t("admin.media.restore_success"),
  purgeSuccess: t("admin.media.purge_success"),
  attachOwnerTypePrompt: t("admin.media.attach_owner_type_prompt"),
  attachOwnerIdPrompt: t("admin.media.attach_owner_id_prompt"),
  detachConfirm: t("admin.media.detach_confirm"),
  deleteReasonPrompt: t("admin.media.delete_reason_prompt"),
  deleteConfirm: t("admin.media.delete_confirm"),
  restoreConfirm: t("admin.media.restore_confirm"),
  purgeConfirm: t("admin.media.purge_confirm"),
  copySuccess: t("admin.media.copy_success"),
  copyFailed: t("admin.media.copy_failed"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

let objects: Awaited<ReturnType<typeof listNewsMediaObjects>> = [];
let loadError = false;

if (CAN_READ) {
  try {
    objects = await withTenant(getDatabaseClient(), context.tenantId, (tx) =>
      listNewsMediaObjects(tx, context.tenantId, {
        status: selectedStatus,
        ownerResourceType: selectedOwnerType,
        includeDeleted
      })
    );
  } catch (error) {
    logAdminPageError(
      "admin/media/index.astro: failed to load media objects",
      error,
      { correlationId: Astro.locals.correlationId }
    );
    loadError = true;
  }
}

function formatSize(bytes: number): string {
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 * 1024) return `${Math.round(bytes / 1024)} KB`;
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
}

// Only raster images get an <img> preview. An SVG is a document the browser
// executes, so rendering one inline would run its script in an authenticated
// admin session.
//
// No stored object can be an SVG today, and this is not a live hole being
// patched: `media-mime-sniffer.ts` can positively recognize exactly four raster
// signatures, and anything else sniffs to `undefined`, which finalize treats as
// a hard reject — so `mime_type` cannot hold `image/svg+xml` even in a
// deployment that allow-lists it via `NEWS_MEDIA_R2_ALLOWED_MIME_TYPES`
// (`media-r2-config.ts` keeps it in the KNOWN set precisely because that
// override path exists).
//
// The guard stays anyway, because what makes it unreachable is a fact about the
// sniffer, not about this page — and step 5c exists specifically to widen the
// set of accepted media types. A preview that opts IN to four known-inert raster
// types fails closed when that day comes; one that trusted the `image/` prefix
// would silently start rendering whatever 5c admits.
const PREVIEWABLE_MIME_TYPES = new Set([
  "image/jpeg",
  "image/png",
  "image/webp",
  "image/gif"
]);

function isPreviewable(mimeType: string): boolean {
  return PREVIEWABLE_MIME_TYPES.has(mimeType);
}
---

<AdminLayout title={t("admin.media.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.media.access_denied_title")}
        body={t("admin.media.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && (
      <div class="media-browser">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        <form class="filter-form" method="get">
          <label>
            {t("admin.media.filter_status")}
            <select name="status">
              <option value="">{t("admin.media.filter_any")}</option>
              {NEWS_MEDIA_OBJECT_STATUSES.map((status) => (
                <option value={status} selected={status === selectedStatus}>
                  {status}
                </option>
              ))}
            </select>
          </label>
          <label>
            {t("admin.media.filter_owner_type")}
            <select name="ownerResourceType">
              <option value="">{t("admin.media.filter_any")}</option>
              {NEWS_MEDIA_OWNER_RESOURCE_TYPES.map((type) => (
                <option value={type} selected={type === selectedOwnerType}>
                  {type}
                </option>
              ))}
            </select>
          </label>
          <label class="checkbox-label">
            <input
              type="checkbox"
              name="includeDeleted"
              value="true"
              checked={includeDeleted}
            />
            {t("admin.media.filter_include_deleted")}
          </label>
          <button type="submit">{t("admin.media.filter_submit")}</button>
        </form>

        {objects.length === 0 ? (
          <p class="empty-state">{t("admin.media.no_objects")}</p>
        ) : (
          <ul class="media-grid">
            {objects.map((object) => (
              <li class="media-card" data-status={object.status}>
                <div class="preview">
                  {isPreviewable(object.mimeType) ? (
                    <img
                      src={object.publicUrl}
                      alt={object.altText ?? object.originalFilename}
                      loading="lazy"
                      width={object.width ?? undefined}
                      height={object.height ?? undefined}
                    />
                  ) : (
                    <span class="preview-fallback">{object.mimeType}</span>
                  )}
                </div>

                <h2 class="filename">{object.originalFilename}</h2>

                <p class="badges">
                  <span class="badge" data-kind="status">
                    {object.deletedAt
                      ? t("admin.media.status_deleted")
                      : object.status}
                  </span>
                  <span class="badge">{object.mimeType}</span>
                  <span class="badge">{formatSize(object.sizeBytes)}</span>
                  {object.width && object.height && (
                    <span class="badge">
                      {object.width}×{object.height}
                    </span>
                  )}
                </p>

                {object.ownerResourceType && (
                  <p class="owner">
                    {t("admin.media.owned_by")} {object.ownerResourceType}{" "}
                    <code>{object.ownerResourceId}</code>
                  </p>
                )}

                {/* The id an editor must paste into the ad-placement /
                    featured-media fields. `readonly` + select-on-focus rather
                    than plain text so it can be copied on a touch device with
                    no clipboard permission prompt. */}
                <label class="id-field">
                  {t("admin.media.object_id")}
                  <span class="id-row">
                    <input type="text" readonly value={object.id} />
                    <button
                      type="button"
                      class="copy-id-button"
                      data-id={object.id}
                    >
                      {t("admin.media.copy_id")}
                    </button>
                  </span>
                </label>

                <div class="actions">
                  {CAN_ATTACH &&
                    !object.deletedAt &&
                    object.status === "verified" && (
                      <button
                        type="button"
                        class="action-button attach-button"
                        data-id={object.id}
                      >
                        {t("admin.media.attach_button")}
                      </button>
                    )}
                  {CAN_DETACH &&
                    !object.deletedAt &&
                    object.status === "attached" && (
                      <button
                        type="button"
                        class="action-button detach-button"
                        data-id={object.id}
                      >
                        {t("admin.media.detach_button")}
                      </button>
                    )}
                  {CAN_DELETE && !object.deletedAt && (
                    <button
                      type="button"
                      class="action-button danger delete-button"
                      data-id={object.id}
                    >
                      {t("admin.media.delete_button")}
                    </button>
                  )}
                  {CAN_RESTORE && object.deletedAt && (
                    <button
                      type="button"
                      class="action-button restore-button"
                      data-id={object.id}
                    >
                      {t("admin.media.restore_button")}
                    </button>
                  )}
                  {CAN_PURGE && object.deletedAt && (
                    <button
                      type="button"
                      class="action-button danger purge-button"
                      data-id={object.id}
                    >
                      {t("admin.media.purge_button")}
                    </button>
                  )}
                </div>
              </li>
            ))}
          </ul>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .media-browser {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
  }

  .action-banner[data-variant="success"] {
    background: color-mix(
      in srgb,
      var(--color-success) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-success);
  }

  .action-banner[data-variant="error"] {
    background: color-mix(
      in srgb,
      var(--color-danger) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-danger);
  }

  .filter-form {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: var(--sp-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }

  .filter-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
  }

  .checkbox-label {
    flex-direction: row !important;
    align-items: center;
    gap: var(--sp-2) !important;
    min-height: 44px;
  }

  .empty-state {
    color: var(--color-text-muted);
  }

  .media-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--sp-3);
  }

  .media-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }

  /* A soft-deleted card stays legible but must never read as live content. */
  .media-card[data-status] .preview img {
    width: 100%;
    height: 160px;
    object-fit: contain;
    background: var(--color-surface-2);
    border-radius: var(--radius-sm);
  }

  .preview-fallback {
    display: grid;
    place-items: center;
    height: 160px;
    background: var(--color-surface-2);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    font-size: var(--fs-xs);
  }

  .filename {
    font-size: var(--fs-sm);
    margin: 0;
    overflow-wrap: anywhere;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-1);
    margin: 0;
  }

  .badge {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0 var(--sp-1);
  }

  .owner {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    margin: 0;
    overflow-wrap: anywhere;
  }

  .id-field {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
  }

  .id-row {
    display: flex;
    gap: var(--sp-1);
  }

  .id-field input {
    flex: 1;
    min-width: 0;
    font-family: var(--font-mono, monospace);
    font-size: var(--fs-xs);
    padding: var(--sp-1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface-2);
    color: var(--color-text);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-1);
    margin-top: auto;
  }

  .action-button,
  .copy-id-button,
  .filter-form button {
    min-height: 44px;
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-2);
    cursor: pointer;
    font-size: var(--fs-xs);
  }

  .filter-form button {
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    padding: var(--sp-1) var(--sp-3);
  }

  .action-button,
  .copy-id-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .action-button.danger {
    border-color: var(--color-danger-strong);
    color: var(--color-danger-strong);
  }

  input:focus-visible,
  select:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface MediaBrowserStrings {
    attachSuccess: string;
    detachSuccess: string;
    deleteSuccess: string;
    restoreSuccess: string;
    purgeSuccess: string;
    attachOwnerTypePrompt: string;
    attachOwnerIdPrompt: string;
    detachConfirm: string;
    deleteReasonPrompt: string;
    deleteConfirm: string;
    restoreConfirm: string;
    purgeConfirm: string;
    copySuccess: string;
    copyFailed: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<MediaBrowserStrings>();

  /**
   * Every lifecycle button is the same shape: confirm, lock, POST/DELETE with a
   * fresh `Idempotency-Key`, banner the outcome, reload on success. `newIdempotencyKey()`
   * is called per attempt on purpose — a retry after a failure is a NEW attempt,
   * and reusing the key would have the server replay the first response.
   */
  function wireAction(
    selector: string,
    handler: (id: string) => {
      url: string;
      method: string;
      body: unknown;
      success: string;
      idempotent: boolean;
    } | null
  ): void {
    document.querySelectorAll(selector).forEach((node) => {
      node.addEventListener("click", async () => {
        const button = node as HTMLButtonElement;
        if (button.disabled) return;

        const plan = handler(button.dataset.id!);
        if (!plan) return;

        const unlock = lockElement(button, strings.pleaseWait);
        try {
          const result = await submitJson(
            plan.url,
            plan.method,
            plan.body,
            strings,
            plan.idempotent
              ? { "Idempotency-Key": newIdempotencyKey() }
              : undefined
          );
          showBanner(
            "action-banner",
            result.ok ? plan.success : result.message,
            result.ok ? "success" : "error"
          );
          if (result.ok) reloadAfterDelay();
        } finally {
          unlock();
        }
      });
    });
  }

  wireAction(".attach-button", (id) => {
    const ownerResourceType = window.prompt(strings.attachOwnerTypePrompt);
    if (!ownerResourceType?.trim()) return null;
    const ownerResourceId = window.prompt(strings.attachOwnerIdPrompt);
    if (!ownerResourceId?.trim()) return null;

    // Neither value is validated here. The route validates `ownerResourceType`
    // against its own allow-list and the owning resource is the caller's to know
    // — a client-side copy of that list would be a second source of truth that
    // drifts, and the error banner already surfaces the server's answer.
    return {
      url: `/api/v1/media/objects/${id}/attach`,
      method: "POST",
      body: {
        ownerResourceType: ownerResourceType.trim(),
        ownerResourceId: ownerResourceId.trim()
      },
      success: strings.attachSuccess,
      idempotent: true
    };
  });

  wireAction(".detach-button", (id) => {
    if (!window.confirm(strings.detachConfirm)) return null;
    return {
      url: `/api/v1/media/objects/${id}/detach`,
      method: "POST",
      body: {},
      success: strings.detachSuccess,
      idempotent: true
    };
  });

  // `DELETE /api/v1/media/objects/{id}` takes a reason and NO Idempotency-Key —
  // matching `DELETE /api/v1/blog/posts/{id}`. Sending one anyway would be
  // ignored, but the asymmetry is deliberate and worth not papering over.
  wireAction(".delete-button", (id) => {
    const reason = window.prompt(strings.deleteReasonPrompt);
    if (!reason?.trim()) return null;
    if (!window.confirm(strings.deleteConfirm)) return null;
    return {
      url: `/api/v1/media/objects/${id}`,
      method: "DELETE",
      body: { reason: reason.trim() },
      success: strings.deleteSuccess,
      idempotent: false
    };
  });

  wireAction(".restore-button", (id) => {
    if (!window.confirm(strings.restoreConfirm)) return null;
    return {
      url: `/api/v1/media/objects/${id}/restore`,
      method: "POST",
      body: {},
      success: strings.restoreSuccess,
      idempotent: true
    };
  });

  wireAction(".purge-button", (id) => {
    if (!window.confirm(strings.purgeConfirm)) return null;
    return {
      url: `/api/v1/media/objects/${id}/purge`,
      method: "POST",
      body: {},
      success: strings.purgeSuccess,
      idempotent: true
    };
  });

  document.querySelectorAll(".copy-id-button").forEach((node) => {
    node.addEventListener("click", async () => {
      const button = node as HTMLButtonElement;
      const id = button.dataset.id!;
      try {
        // `navigator.clipboard` is unavailable on an insecure origin, so this
        // can genuinely fail. The id is visible and selectable in the input
        // beside the button regardless — the copy is a convenience, not the
        // only way to get the value.
        await navigator.clipboard.writeText(id);
        showBanner("action-banner", strings.copySuccess, "success");
      } catch {
        showBanner("action-banner", strings.copyFailed, "error");
      }
    });
  });
</script>
