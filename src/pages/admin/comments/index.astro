---
/**
 * Comments moderation queue admin screen (Issue #271, ADR-0032). Surfaces the
 * ABAC-guarded `GET /api/v1/comments/admin/queue` + moderation endpoints; this
 * page adds no new endpoint and never queries `awcms_micro_comments_*` directly.
 * Every action goes through the real HTTP API, which re-checks RBAC/ABAC on the
 * server — the SSR permission check here is a UI convenience layer only (doc 10:
 * "the UI must not be the only enforcement point"). Comment bodies are shown as
 * plain text (never rendered HTML) on the moderation surface.
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import { createTranslator } from "../../../lib/i18n/translate";

const context = Astro.locals.ssrContext;
if (!context) {
  throw new Error(
    "admin/comments/index.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("comments", "moderation", "read")
);

const clientStrings = {
  loadError: t("common.network_error"),
  reasonPrompt: t("admin.comments.reason_prompt"),
  actionError: t("admin.comments.action_error"),
  empty: t("admin.comments.empty"),
  approve: t("admin.comments.approve"),
  reject: t("admin.comments.reject"),
  spam: t("admin.comments.spam"),
  archive: t("admin.comments.archive"),
  restore: t("admin.comments.restore"),
  reports: t("admin.comments.reports"),
  statusLabel: t("admin.comments.status_label")
};
---

<AdminLayout title={t("admin.comments.page_title")}>
  <h1>{t("admin.comments.page_title")}</h1>
  <p>{t("admin.comments.page_description")}</p>

  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.comments.access_denied_title")}
        body={t("admin.comments.access_denied_body")}
      />
    )
  }

  {
    CAN_READ && (
      <section
        class="comments-admin"
        data-comments-admin
        data-tenant-id={context.tenantId}
        data-strings={JSON.stringify(clientStrings)}
      >
        <p
          class="comments-admin__banner"
          data-queue-banner
          role="status"
          aria-live="polite"
        />

        <div class="comments-admin__filter">
          <label for="comments-status-filter">
            {t("admin.comments.filter_label")}
          </label>
          <select id="comments-status-filter" data-queue-status>
            <option value="pending">
              {t("admin.comments.status_pending")}
            </option>
            <option value="approved">
              {t("admin.comments.status_approved")}
            </option>
            <option value="rejected">
              {t("admin.comments.status_rejected")}
            </option>
            <option value="spam">{t("admin.comments.status_spam")}</option>
            <option value="deleted">
              {t("admin.comments.status_deleted")}
            </option>
          </select>
        </div>

        <ul class="comments-admin__list" data-queue-list>
          {[0, 1, 2].map(() => (
            <li class="comments-admin__item" data-skeleton aria-hidden="true">
              <div class="awcms-skeleton comments-admin__skeleton comments-admin__skeleton--meta" />
              <div class="awcms-skeleton comments-admin__skeleton comments-admin__skeleton--body" />
            </li>
          ))}
        </ul>
        <p class="comments-admin__empty" data-queue-empty hidden>
          {t("admin.comments.empty")}
        </p>
      </section>
    )
  }
</AdminLayout>

<style>
  .comments-admin__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .comments-admin__item {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3) var(--sp-4);
  }
  .comments-admin__meta {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }
  .comments-admin__body {
    margin-block: var(--sp-2);
    overflow-wrap: anywhere;
    white-space: pre-wrap;
  }
  .comments-admin__actions {
    display: flex;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .comments-admin__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: var(--sp-2) var(--sp-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
    cursor: pointer;
    font: inherit;
    transition: var(--transition-colors);
  }
  .comments-admin__action:hover {
    background: var(--color-surface-2);
  }
  .comments-admin__action:active {
    transform: scale(0.97);
  }
  .comments-admin__filter {
    margin-block: var(--sp-4);
    display: flex;
    gap: var(--sp-2);
    align-items: center;
  }
  .comments-admin__filter select {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }
  .comments-admin__skeleton {
    height: var(--sp-3);
  }
  .comments-admin__skeleton--meta {
    width: 40%;
    margin-bottom: var(--sp-2);
  }
  .comments-admin__skeleton--body {
    width: 80%;
    height: var(--sp-4);
  }
  .comments-admin__banner:empty {
    display: none;
  }
  .comments-admin__banner[data-tone="error"] {
    color: var(--color-danger);
  }
  .comments-admin__banner[data-tone="success"] {
    color: var(--color-success);
  }
</style>

<script>
  import { initCommentsAdmin } from "../../../lib/comments/comments-admin-client";
  document
    .querySelectorAll<HTMLElement>("[data-comments-admin]")
    .forEach((el) => {
      initCommentsAdmin(el);
    });
</script>
