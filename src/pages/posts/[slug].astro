---
import {
  decodeSlug,
  getEmDashCollection,
  getEmDashEntry,
  getEntryTerms,
  getSeoMeta,
  getSiteSettings,
} from "emdash";
import { CommentForm, Comments, PortableText, WidgetArea } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import { getReadingTime } from "../../utils/reading-time";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
  return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
  return Astro.redirect("/404");
}

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const [terms, settings, { entries: recentPosts }] = await Promise.all([
  Promise.all([
    getEntryTerms("posts", post.data.id, "category"),
    getEntryTerms("posts", post.data.id, "tag"),
  ]),
  getSiteSettings(),
  getEmDashCollection("posts", { orderBy: { published_at: "desc" }, limit: 4 }),
]);

const [categories, tags] = terms;
const siteTitle = settings?.title ?? "AWCMS-Micro";
const seo = getSeoMeta(post, {
  siteTitle,
  siteUrl: Astro.url.origin,
  path: `/posts/${slug}`,
});
const readingTime = getReadingTime(post.data.content);
const relatedPosts = recentPosts.filter((entry) => entry.id !== post.id).slice(0, 3);
---

<Base
  title={seo.title}
  pageTitle={seo.ogTitle}
  description={seo.description}
  image={seo.ogImage}
  canonical={seo.canonical}
  robots={seo.robots}
  type="article"
  publishedTime={post.data.publishedAt?.toISOString() ?? null}
  modifiedTime={post.data.updatedAt.toISOString()}
  content={{ collection: "posts", id: post.data.id, slug }}
>
  <article class="post-detail">
    <header class="post-header">
      <h1 {...post.edit.title}>{post.data.title}</h1>
      <div class="post-meta">
        {post.data.publishedAt && (
          <time datetime={post.data.publishedAt.toISOString()}>
            {post.data.publishedAt.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </time>
        )}
        {post.data.publishedAt && <span class="meta-dot" />}
        <span>{readingTime} min read</span>
      </div>
    </header>

    {categories.length > 0 && (
      <div class="categories">
        {categories.map((term) => (
          <a href={`/category/${term.slug}`} class="category-chip">
            {term.label}
          </a>
        ))}
      </div>
    )}

    <div class="post-content">
      {post.data.excerpt && <p class="excerpt" {...post.edit.excerpt}>{post.data.excerpt}</p>}
      <PortableText value={post.data.content} />
    </div>

    {tags.length > 0 && (
      <div class="tags">
        {tags.map((term) => (
          <a href={`/tag/${term.slug}`} class="tag-chip">
            {term.label}
          </a>
        ))}
      </div>
    )}

    <aside class="widget-sidebar">
      <WidgetArea name="sidebar" />
    </aside>

    <section class="comments-section">
      <Comments collection="posts" contentId={post.data.id} threaded />
      <CommentForm collection="posts" contentId={post.data.id} />
    </section>

    {relatedPosts.length > 0 && (
      <section class="related-posts">
        <h2>Recent Posts</h2>
        <ul>
          {relatedPosts.map((entry) => (
            <li><a href={`/posts/${entry.id}`}>{entry.data.title}</a></li>
          ))}
        </ul>
      </section>
    )}
  </article>
</Base>

<style>
  .post-detail {
    max-width: var(--content-width, 680px);
    margin: 0 auto;
    display: grid;
    gap: var(--spacing-6);
  }

  h1 {
    font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--spacing-3);
  }

  .post-meta {
    display: flex;
    gap: var(--spacing-3);
    color: var(--color-text-secondary, #666);
    font-size: var(--font-size-sm);
  }

  .categories, .tags {
    display: flex;
    gap: var(--spacing-2);
    flex-wrap: wrap;
  }

  .category-chip, .tag-chip {
    padding: var(--tag-padding-y) var(--spacing-2);
    border-radius: var(--radius);
    font-size: var(--font-size-xs);
    text-decoration: none;
    background: var(--color-bg-subtle, #f5f5f5);
    color: var(--color-text-secondary, #666);
  }

  .category-chip:hover, .tag-chip:hover {
    background: var(--color-accent, #0066cc);
    color: white;
  }

  .post-content {
    line-height: var(--leading-relaxed);
  }

  .excerpt {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-5);
  }

  .meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-muted);
    margin-top: 0.55rem;
  }

  .widget-sidebar,
  .comments-section,
  .related-posts {
    border-top: 1px solid var(--color-border-subtle);
    padding-top: var(--spacing-6);
  }

  .related-posts ul {
    margin-top: var(--spacing-3);
    padding-left: var(--spacing-5);
  }
</style>
