---
/**
 * `GET /newsletter/demo` (Issue #272, ADR-0033) — a public, host-resolved
 * reference page with a subscribe form that POSTs to the ANTI-ENUMERATION
 * `/api/v1/newsletter/subscribe` endpoint. Production sites embed their own form;
 * this route exists as a working reference and the E2E target. Tenant is resolved
 * server-side from the request host by the API — this page trusts no client tenant.
 * The response is always a generic acknowledgement (never reveals existence), so
 * the UI shows the SAME confirmation regardless of the address's state.
 */
import { createTranslator } from "../../lib/i18n/translate";

const t = await createTranslator(Astro.locals.locale);
Astro.response.headers.set("X-Robots-Tag", "noindex, nofollow");
---

<!doctype html>
<html lang={Astro.locals.locale ?? "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{t("newsletter.public.heading")}</title>
  </head>
  <body>
    <main
      class="newsletter-demo"
      style="max-width: 34rem; margin: 2rem auto; padding: 0 1rem;"
    >
      <h1>{t("newsletter.public.heading")}</h1>
      <p>{t("newsletter.public.description")}</p>

      <form data-newsletter-subscribe novalidate>
        <label for="newsletter-email"
          >{t("newsletter.public.email_label")}</label
        >
        <input
          id="newsletter-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          style="display:block; width:100%; padding:0.5rem; margin:0.5rem 0 1rem;"
        />
        <button type="submit">{t("newsletter.public.subscribe_button")}</button>
      </form>

      <p
        class="newsletter-demo__note"
        data-newsletter-note
        role="status"
        aria-live="polite"
        hidden
      >
        {t("newsletter.public.subscribed_note")}
      </p>
    </main>

    <script>
      const form = document.querySelector<HTMLFormElement>(
        "[data-newsletter-subscribe]"
      );
      const note = document.querySelector<HTMLElement>(
        "[data-newsletter-note]"
      );
      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const email = new FormData(form).get("email");
        try {
          await fetch("/api/v1/newsletter/subscribe", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ email })
          });
        } catch {
          /* Anti-enumeration: the same confirmation is shown regardless. */
        }
        // ALWAYS show the same generic confirmation (never reveal existence).
        if (note) note.hidden = false;
        form.reset();
      });
    </script>
  </body>
</html>
