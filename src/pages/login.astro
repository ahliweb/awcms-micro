---
/**
 * Login page (Issue 8.1; redesigned into a modern, mobile-first auth screen
 * on the shared `src/styles/auth.css` surface — same look as the forgot /
 * reset / register screens). Posts to `POST /api/v1/auth/login`, which sets
 * the two httpOnly SSR session cookies (`src/pages/api/v1/auth/login.ts`)
 * consumed by `src/lib/auth/ssr-session.ts` / `src/layouts/AdminLayout.astro`.
 *
 * ## Stable DOM contract (do not rename — client script + E2E depend on
 * these): `#login-form`, `#tenant-id`, `#login-identifier`, `#password`,
 * `#login-submit`, `#login-error`. The tenant field ALWAYS carries
 * `name="tenantId"` and id `#tenant-id` regardless of which of the three
 * shapes it takes (single readout / select / manual), so both
 * `FormData.get("tenantId")` and the Google-login button (reads `#tenant-id`'s
 * `.value`) keep working and the submit still sends the tenant header.
 *
 * Theme (doc 14 §Theming): imports tokens.css, so it MUST also run
 * `THEME_INIT_SCRIPT_BODY` before paint — otherwise the `[data-theme="dark"]`
 * overrides never apply and the page is light-only under OS dark (fix #313).
 *
 * i18n (Issue #433): `Astro.locals.locale` is cookie-only resolved (no tenant
 * known yet pre-login — see `src/middleware.ts`). The client-side `<script>`
 * cannot read the `.po` catalog itself (server-side only via `Bun.file`), so
 * the strings/error-code map it needs are injected as a
 * `<script type="application/json">` blob — the same pattern the admin pages'
 * action banners use.
 *
 * Cloudflare Turnstile (Issue #588) — the widget only renders when
 * `isTurnstileRequired()` is true; every local/offline/LAN deployment renders
 * this page without it. `TURNSTILE_SITE_KEY` is public.
 *
 * Google OIDC login (Issue #590) — the "Continue with Google" button only
 * renders when `isGoogleLoginRequired()` is true; the destination URL needs
 * the Tenant ID field's CURRENT value at click time.
 *
 * ## Auto tenant picker (AUTH_LOGIN_TENANT_PICKER)
 * When opted in, `listActiveTenantsForLogin()` reads the active tenant registry
 * (id + name only) and the shape adapts to the count: exactly 1 → a read-only
 * "Signing in to <name>" readout with a HIDDEN `#tenant-id`; 2+ → a `<select>`
 * of tenant names (value = UUID). When the picker is off (or on but the
 * registry read yields 0 rows) the manual Tenant ID text field is rendered.
 *
 * Motion: the card entrance animates transform ONLY (never opacity), so an
 * axe-core contrast scan can never catch semi-transparent text mid-animation.
 * All motion routes through the shared motion tokens and is neutralised by the
 * global `prefers-reduced-motion` reset in tokens.css.
 */
import "../styles/tokens.css";
import "../styles/auth.css";
import { createTranslator } from "../lib/i18n/translate";
import { buildClientErrorMessages } from "../lib/i18n/error-messages";
import { isTurnstileRequired } from "../lib/security/turnstile";
import { isGoogleLoginRequired } from "../lib/auth/google-oidc-config";
import { isSelfRegistrationEnabled } from "../lib/auth/self-registration-config";
import { THEME_INIT_SCRIPT_BODY } from "../lib/security/theme-init-script";
import {
  isLoginTenantPickerEnabled,
  listActiveTenantsForLogin,
  type LoginTenantOption
} from "../lib/auth/login-tenant-picker";

const locale = Astro.locals.locale;
const t = await createTranslator(locale);
const turnstileActive = isTurnstileRequired();
const turnstileSiteKey = turnstileActive
  ? process.env.TURNSTILE_SITE_KEY
  : null;
const googleLoginActive = isGoogleLoginRequired();
const registrationActive = isSelfRegistrationEnabled();

// Opt-in tenant picker (AUTH_LOGIN_TENANT_PICKER) — see file header. The list
// is only queried when the operator has opted in, since it exposes tenant
// names pre-auth (see login-tenant-picker.ts).
const tenantPickerActive = isLoginTenantPickerEnabled();
const tenantOptions: LoginTenantOption[] = tenantPickerActive
  ? await listActiveTenantsForLogin()
  : [];

const singleTenant =
  tenantPickerActive && tenantOptions.length === 1 ? tenantOptions[0]! : null;
const tenantSelect = tenantPickerActive && tenantOptions.length >= 2;
// Picker off, or on but registry empty → keep the manual text field.
const tenantManual = !tenantPickerActive || tenantOptions.length === 0;

const clientStrings = {
  genericError: t("auth.login.generic_error"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  submitLabel: t("auth.login.submit"),
  passwordShow: t("auth.password_show"),
  passwordHide: t("auth.password_hide"),
  passwordShowAria: t("auth.password_show_aria"),
  passwordHideAria: t("auth.password_hide_aria"),
  // Login MFA challenge step (epic #587-#593 browser UX) — used when the
  // server answers the login POST with `401 MFA_REQUIRED`. Harmless on
  // deployments where MFA is off (that response never happens there).
  mfaCodeLabel: t("auth.mfa.code_label"),
  mfaRecoveryLabel: t("auth.mfa.recovery_label"),
  mfaUseRecovery: t("auth.mfa.use_recovery"),
  mfaUseTotp: t("auth.mfa.use_totp"),
  errorMessages: buildClientErrorMessages(t)
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{t("auth.login.page_title")}</title>
    <script is:inline set:html={THEME_INIT_SCRIPT_BODY} />
  </head>
  <body class="auth-body">
    <main class="auth">
      <div class="auth-card">
        <div class="auth-head">
          <a href="/" class="auth-brand">
            <span class="auth-mark" aria-hidden="true">A</span>
            <span class="auth-wordmark">AWCMS-Micro</span>
          </a>
          <h1 class="auth-title">{t("auth.login.heading")}</h1>
          <p class="auth-subtitle">{t("auth.login.subtitle")}</p>
        </div>

        <form id="login-form" class="auth-form" novalidate>
          <p id="login-error" class="auth-error" role="alert" hidden></p>

          {
            singleTenant && (
              <div class="auth-tenant-context">
                <span class="auth-tenant-context-label">
                  {t("auth.login.tenant_context_label")}
                </span>
                <span class="auth-tenant-context-name">
                  {singleTenant.name}
                </span>
                <input
                  id="tenant-id"
                  name="tenantId"
                  type="hidden"
                  value={singleTenant.id}
                />
              </div>
            )
          }

          {
            tenantSelect && (
              <div class="auth-field">
                <label for="tenant-id">{t("auth.login.tenant_label")}</label>
                <div class="auth-select">
                  <select id="tenant-id" name="tenantId" required>
                    {tenantOptions.map((tenant) => (
                      <option value={tenant.id}>{tenant.name}</option>
                    ))}
                  </select>
                </div>
              </div>
            )
          }

          {
            tenantManual && (
              <div class="auth-field">
                <label for="tenant-id">{t("auth.login.tenant_id_label")}</label>
                <input
                  id="tenant-id"
                  name="tenantId"
                  type="text"
                  required
                  autocomplete="off"
                  spellcheck={false}
                />
              </div>
            )
          }

          <div class="auth-field">
            <label for="login-identifier">
              {t("auth.login.identifier_label")}
            </label>
            <input
              id="login-identifier"
              name="loginIdentifier"
              type="text"
              required
              autocomplete="username"
              spellcheck={false}
            />
          </div>

          <div class="auth-field">
            <label for="password">{t("auth.login.password_label")}</label>
            <div class="auth-password">
              <input
                id="password"
                name="password"
                type="password"
                required
                autocomplete="current-password"
              />
              <button
                type="button"
                id="password-toggle"
                class="auth-password-toggle"
                aria-pressed="false"
                aria-controls="password"
                aria-label={t("auth.password_show_aria")}
              >
                <span class="auth-password-toggle-label">
                  {t("auth.password_show")}
                </span>
              </button>
            </div>
          </div>

          {
            turnstileActive && turnstileSiteKey && (
              <div
                class="cf-turnstile auth-turnstile"
                data-sitekey={turnstileSiteKey}
              />
            )
          }

          <button type="submit" id="login-submit" class="auth-submit">
            {t("auth.login.submit")}
          </button>

          {
            googleLoginActive && (
              <button
                type="button"
                id="google-login-button"
                class="auth-google"
              >
                {t("auth.login.google_button")}
              </button>
            )
          }
        </form>

        {
          /* Second-step MFA challenge (epic #587-#593). Always present but
            inert — revealed by the client script only when the login POST
            answers `401 MFA_REQUIRED`, which only happens on deployments with
            2FA active. Stable ids for E2E: #mfa-challenge, #mfa-code,
            #mfa-submit, #mfa-error, #mfa-use-recovery. */
        }
        <form id="mfa-challenge" class="auth-form" novalidate hidden>
          <div class="auth-head">
            <h2 class="auth-title">{t("auth.mfa.challenge_title")}</h2>
            <p class="auth-subtitle">{t("auth.mfa.challenge_subtitle")}</p>
          </div>

          <p id="mfa-error" class="auth-error" role="alert" hidden></p>

          <div class="auth-field">
            <label for="mfa-code" id="mfa-code-label">
              {t("auth.mfa.code_label")}
            </label>
            <input
              id="mfa-code"
              name="code"
              type="text"
              inputmode="numeric"
              autocomplete="one-time-code"
              pattern="[0-9]*"
              maxlength="8"
              required
              spellcheck={false}
            />
          </div>

          <button type="submit" id="mfa-submit" class="auth-submit">
            {t("auth.mfa.submit")}
          </button>

          <button type="button" id="mfa-use-recovery" class="auth-google">
            {t("auth.mfa.use_recovery")}
          </button>
        </form>

        <nav class="auth-links" aria-label={t("auth.nav_label")}>
          <a href="/forgot-password">{t("auth.login.forgot_link")}</a>
          {
            registrationActive && (
              <a href="/register">{t("auth.login.register_link")}</a>
            )
          }
        </nav>

        <p class="auth-foot">{t("auth.login.footer")}</p>
      </div>
    </main>

    {
      turnstileActive && turnstileSiteKey && (
        <script
          src="https://challenges.cloudflare.com/turnstile/v0/api.js"
          async
          defer
        />
      )
    }

    <script
      type="application/json"
      id="i18n-strings"
      set:html={JSON.stringify(clientStrings)}
    />

    <script>
      import {
        lockElement,
        readClientStrings
      } from "../lib/ui/admin-form-client";
      import { wirePasswordToggle } from "../lib/ui/password-toggle";

      interface LoginStrings {
        genericError: string;
        networkError: string;
        pleaseWait: string;
        passwordShow: string;
        passwordHide: string;
        passwordShowAria: string;
        passwordHideAria: string;
        mfaCodeLabel: string;
        mfaRecoveryLabel: string;
        mfaUseRecovery: string;
        mfaUseTotp: string;
        errorMessages?: Record<string, string>;
      }

      const form = document.getElementById(
        "login-form"
      ) as HTMLFormElement | null;
      const errorBox = document.getElementById("login-error");
      const submitButton = document.getElementById(
        "login-submit"
      ) as HTMLButtonElement | null;
      const strings = readClientStrings<LoginStrings>();

      wirePasswordToggle("password", "password-toggle", strings);

      function showError(message: string): void {
        if (!errorBox) return;
        errorBox.textContent = message;
        errorBox.hidden = false;
        // Transform-only entrance (replay on each new error): remove → reflow
        // → re-add. Token-driven and reduced-motion-safe (tokens.css).
        errorBox.classList.remove("auth-banner--enter");
        void errorBox.offsetWidth;
        errorBox.classList.add("auth-banner--enter");
      }

      function hideError(): void {
        if (!errorBox) return;
        errorBox.hidden = true;
        errorBox.classList.remove("auth-banner--enter");
      }

      // ── Second-step MFA challenge (epic #587-#593) ──────────────────────
      // These elements always exist (rendered inert), so the whole block is a
      // no-op on deployments where the server never returns `MFA_REQUIRED`.
      const mfaForm = document.getElementById(
        "mfa-challenge"
      ) as HTMLFormElement | null;
      const mfaCodeInput = document.getElementById(
        "mfa-code"
      ) as HTMLInputElement | null;
      const mfaCodeLabel = document.getElementById("mfa-code-label");
      const mfaSubmit = document.getElementById(
        "mfa-submit"
      ) as HTMLButtonElement | null;
      const mfaErrorBox = document.getElementById("mfa-error");
      const mfaRecoveryToggle = document.getElementById(
        "mfa-use-recovery"
      ) as HTMLButtonElement | null;

      // Carried from the successful password step to authenticate the verify
      // call (the tenant header + the possession token the server issued).
      let mfaTenantId = "";
      let mfaChallengeToken = "";
      let mfaUsingRecovery = false;

      function showMfaError(message: string): void {
        if (!mfaErrorBox) return;
        mfaErrorBox.textContent = message;
        mfaErrorBox.hidden = false;
        mfaErrorBox.classList.remove("auth-banner--enter");
        void mfaErrorBox.offsetWidth;
        mfaErrorBox.classList.add("auth-banner--enter");
      }

      function hideMfaError(): void {
        if (!mfaErrorBox) return;
        mfaErrorBox.hidden = true;
        mfaErrorBox.classList.remove("auth-banner--enter");
      }

      function revealMfaChallenge(): void {
        if (form) form.hidden = true;
        if (mfaForm) mfaForm.hidden = false;
        mfaCodeInput?.focus();
      }

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        // Issue #434 (UX/UI audit): guard + disable the submit button for the
        // duration of the request — a fast double-click (or double Enter)
        // could otherwise fire two login POSTs before the first redirect
        // landed (doc 14 §Form UX "cegah double-submit").
        if (!submitButton || submitButton.disabled) {
          return;
        }
        const unlock = lockElement(submitButton, strings.pleaseWait);

        hideError();

        const formData = new FormData(form);
        const tenantId = String(formData.get("tenantId") ?? "").trim();
        const loginIdentifier = String(
          formData.get("loginIdentifier") ?? ""
        ).trim();
        const password = String(formData.get("password") ?? "");
        // Cloudflare Turnstile (Issue #588) auto-injects a hidden
        // `cf-turnstile-response` field into this form once solved — absent
        // entirely when the widget isn't rendered (Turnstile not required for
        // this deployment), matching the server's own optional field.
        const turnstileToken = formData.get("cf-turnstile-response");

        try {
          const response = await fetch("/api/v1/auth/login", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-AWCMS-Micro-Tenant-ID": tenantId
            },
            credentials: "same-origin",
            body: JSON.stringify({
              loginIdentifier,
              password,
              ...(turnstileToken ? { turnstileToken } : {})
            })
          });

          const payload = await response.json().catch(() => null);

          // MFA gate (epic #587-#593): the password was correct but the
          // account has 2FA enabled, so the server paused login with a
          // challenge instead of a session. Reveal the second step rather
          // than surfacing this as an error.
          if (
            response.status === 401 &&
            payload?.error?.code === "MFA_REQUIRED"
          ) {
            const token = payload?.error?.details?.mfaChallengeToken;
            if (typeof token === "string" && token.length > 0) {
              mfaTenantId = tenantId;
              mfaChallengeToken = token;
              unlock();
              revealMfaChallenge();
              return;
            }
          }

          if (!response.ok || !payload || payload.success !== true) {
            const code = payload?.error?.code as string | undefined;
            const localized = code ? strings.errorMessages?.[code] : null;
            showError(localized ?? strings.genericError);
            unlock();
            return;
          }

          // Navigating away — leave the button disabled/busy rather than
          // unlocking, so it can't be clicked again during the redirect.
          window.location.href = "/admin";
        } catch {
          showError(strings.networkError);
          unlock();
        }
      });

      // Google OIDC login (Issue #590) — the destination needs the Tenant ID
      // field's CURRENT value, read at click time, as a `?tenantId=` query
      // param (this page has no tenant cookie yet pre-login, and a plain
      // navigation can't carry the `X-AWCMS-Micro-Tenant-ID` header every
      // fetch-based call on this page uses instead).
      const googleButton = document.getElementById(
        "google-login-button"
      ) as HTMLButtonElement | null;

      googleButton?.addEventListener("click", () => {
        const tenantId = String(
          (document.getElementById("tenant-id") as HTMLInputElement | null)
            ?.value ?? ""
        ).trim();

        if (!tenantId) {
          showError(strings.genericError);
          return;
        }

        window.location.href = `/api/v1/auth/providers/google/start?tenantId=${encodeURIComponent(tenantId)}`;
      });

      // Toggle between the authenticator (TOTP) code and a one-time recovery
      // code, updating the field's label + input constraints accordingly.
      mfaRecoveryToggle?.addEventListener("click", () => {
        mfaUsingRecovery = !mfaUsingRecovery;
        hideMfaError();

        if (mfaCodeInput) {
          mfaCodeInput.value = "";
          if (mfaUsingRecovery) {
            mfaCodeInput.setAttribute("inputmode", "text");
            mfaCodeInput.removeAttribute("pattern");
            mfaCodeInput.setAttribute("maxlength", "9");
          } else {
            mfaCodeInput.setAttribute("inputmode", "numeric");
            mfaCodeInput.setAttribute("pattern", "[0-9]*");
            mfaCodeInput.setAttribute("maxlength", "8");
          }
          mfaCodeInput.focus();
        }
        if (mfaCodeLabel) {
          mfaCodeLabel.textContent = mfaUsingRecovery
            ? strings.mfaRecoveryLabel
            : strings.mfaCodeLabel;
        }
        if (mfaRecoveryToggle) {
          mfaRecoveryToggle.textContent = mfaUsingRecovery
            ? strings.mfaUseTotp
            : strings.mfaUseRecovery;
        }
      });

      mfaForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!mfaSubmit || mfaSubmit.disabled) return;

        const value = String(mfaCodeInput?.value ?? "").trim();
        if (value.length === 0) {
          showMfaError(strings.genericError);
          return;
        }

        const unlock = lockElement(mfaSubmit, strings.pleaseWait);
        hideMfaError();

        try {
          const response = await fetch("/api/v1/auth/mfa/totp/verify", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-AWCMS-Micro-Tenant-ID": mfaTenantId
            },
            credentials: "same-origin",
            body: JSON.stringify({
              mfaChallengeToken,
              ...(mfaUsingRecovery ? { recoveryCode: value } : { code: value })
            })
          });

          const payload = await response.json().catch(() => null);

          if (!response.ok || !payload || payload.success !== true) {
            const code = payload?.error?.code as string | undefined;
            const localized = code ? strings.errorMessages?.[code] : null;
            showMfaError(
              localized ?? payload?.error?.message ?? strings.genericError
            );
            unlock();
            return;
          }

          // Same success path as the plain login: session cookie is set,
          // navigate to the admin shell (leave the button locked).
          window.location.href = "/admin";
        } catch {
          showMfaError(strings.networkError);
          unlock();
        }
      });
    </script>
  </body>
</html>
