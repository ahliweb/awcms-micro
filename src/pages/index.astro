<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AWCMS-Micro</title>
    <style>
      /* WCAG 2.2 AA 2.5.8 Target Size (Minimum): give the foundation links a
         ≥24px touch target + spacing so axe target-size passes. */
      main {
        max-width: 40rem;
        margin: 2rem auto;
        padding: 0 1rem;
        line-height: 1.6;
      }
      ul {
        list-style: none;
        padding: 0;
      }
      li {
        margin: 0.75rem 0;
      }
      li a {
        display: inline-block;
        padding: 6px 4px;
        min-height: 24px;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>AWCMS-Micro</h1>
      <p>Bun + Astro 7 + PostgreSQL modular monolith foundation.</p>
      <ul>
        <li><a href="/api/v1/health">Health endpoint</a></li>
        <li>
          <a href="https://github.com/ahliweb/awcms-micro/tree/main/docs">
            Dokumentasi
          </a>
        </li>
      </ul>
    </main>
  </body>
</html>
