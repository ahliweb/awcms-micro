---
/**
 * Reset-password page (Issue #496 UI). Completes a reset via
 * `POST /api/v1/auth/password/reset` ({ token, newPassword } + tenant header).
 *
 * The link emailed by `forgot.ts` is `${APP_URL}/reset-password?token=<raw>
 * &tenantId=<uuid>` — the endpoint is tenant-scoped (RLS) so the page reads
 * both from the query. `token` is single-use + short-lived; embedding it in a
 * hidden field is standard (it is already in the user's own URL). If the
 * tenant is missing from the link (older link / manual navigation), a manual
 * tenant field is shown as a fallback. No token at all → an "invalid link"
 * state that routes the user back to /forgot-password.
 *
 * Generic failure (mirrors the endpoint): the API never distinguishes
 * not-found vs expired vs used, so this page shows one localized generic error
 * on any rejection. Shares the `src/styles/auth.css` surface.
 */
import "../styles/tokens.css";
import "../styles/auth.css";
import { createTranslator } from "../lib/i18n/translate";
import { buildClientErrorMessages } from "../lib/i18n/error-messages";
import { THEME_INIT_SCRIPT_BODY } from "../lib/security/theme-init-script";
import { openUrlParams } from "../lib/security/secure-url-params";

const locale = Astro.locals.locale;
const t = await createTranslator(locale);

// The reset link is either the sealed shape `?p=<opaque>` (when
// AUTH_URL_PARAM_ENCRYPTION_KEY is set — token+tenant AES-256-GCM encrypted)
// or plain `?token=…&tenantId=…`. Decoding is server-side only (the key never
// reaches the client); the recovered values are then embedded as hidden fields
// exactly as before.
const sealed = Astro.url.searchParams.get("p")?.trim() ?? "";
let token = "";
let tenantId = "";
if (sealed) {
  const opened = openUrlParams(sealed);
  token = opened?.token?.trim() ?? "";
  tenantId = opened?.tenantId?.trim() ?? "";
} else {
  token = Astro.url.searchParams.get("token")?.trim() ?? "";
  tenantId = Astro.url.searchParams.get("tenantId")?.trim() ?? "";
}
const hasToken = token.length > 0;

const clientStrings = {
  genericError: t("auth.reset.generic_error"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  mismatch: t("auth.reset.mismatch"),
  tooShort: t("auth.reset.too_short"),
  success: t("auth.reset.success"),
  passwordShow: t("auth.password_show"),
  passwordHide: t("auth.password_hide"),
  passwordShowAria: t("auth.password_show_aria"),
  passwordHideAria: t("auth.password_hide_aria"),
  errorMessages: buildClientErrorMessages(t)
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{t("auth.reset.page_title")}</title>
    <script is:inline set:html={THEME_INIT_SCRIPT_BODY} />
  </head>
  <body class="auth-body">
    <main class="auth">
      <div class="auth-card">
        <div class="auth-head">
          <a href="/" class="auth-brand">
            <span class="auth-mark" aria-hidden="true">A</span>
            <span class="auth-wordmark">AWCMS-Micro</span>
          </a>
          <h1 class="auth-title">{t("auth.reset.heading")}</h1>
          <p class="auth-subtitle">{t("auth.reset.subtitle")}</p>
        </div>

        {
          !hasToken ? (
            <>
              <p class="auth-error" role="alert">
                {t("auth.reset.invalid_link")}
              </p>
              <nav class="auth-links" aria-label={t("auth.nav_label")}>
                <a href="/forgot-password">{t("auth.reset.request_new")}</a>
                <a href="/login">{t("auth.back_to_login")}</a>
              </nav>
            </>
          ) : (
            <>
              <form id="reset-form" class="auth-form" novalidate>
                <p id="reset-error" class="auth-error" role="alert" hidden />
                <p id="reset-notice" class="auth-notice" role="status" hidden />

                <input
                  id="reset-token"
                  name="token"
                  type="hidden"
                  value={token}
                />

                {tenantId ? (
                  <input
                    id="tenant-id"
                    name="tenantId"
                    type="hidden"
                    value={tenantId}
                  />
                ) : (
                  <div class="auth-field">
                    <label for="tenant-id">
                      {t("auth.login.tenant_id_label")}
                    </label>
                    <input
                      id="tenant-id"
                      name="tenantId"
                      type="text"
                      required
                      autocomplete="off"
                      spellcheck={false}
                    />
                  </div>
                )}

                <div class="auth-field">
                  <label for="new-password">
                    {t("auth.reset.password_label")}
                  </label>
                  <div class="auth-password">
                    <input
                      id="new-password"
                      name="newPassword"
                      type="password"
                      required
                      autocomplete="new-password"
                      minlength="8"
                    />
                    <button
                      type="button"
                      id="new-password-toggle"
                      class="auth-password-toggle"
                      aria-pressed="false"
                      aria-controls="new-password"
                      aria-label={t("auth.password_show_aria")}
                    >
                      <span class="auth-password-toggle-label">
                        {t("auth.password_show")}
                      </span>
                    </button>
                  </div>
                  <p class="auth-hint">{t("auth.reset.password_hint")}</p>
                </div>

                <div class="auth-field">
                  <label for="confirm-password">
                    {t("auth.reset.confirm_label")}
                  </label>
                  <input
                    id="confirm-password"
                    name="confirmPassword"
                    type="password"
                    required
                    autocomplete="new-password"
                  />
                </div>

                <button type="submit" id="reset-submit" class="auth-submit">
                  {t("auth.reset.submit")}
                </button>
              </form>

              <nav
                class="auth-links"
                id="reset-login-link"
                aria-label={t("auth.nav_label")}
                hidden
              >
                <a href="/login">{t("auth.reset.success_login_link")}</a>
              </nav>
            </>
          )
        }
      </div>
    </main>

    <script
      type="application/json"
      id="i18n-strings"
      set:html={JSON.stringify(clientStrings)}
    />

    <script>
      import {
        lockElement,
        readClientStrings
      } from "../lib/ui/admin-form-client";
      import { wirePasswordToggle } from "../lib/ui/password-toggle";

      interface ResetStrings {
        genericError: string;
        networkError: string;
        pleaseWait: string;
        mismatch: string;
        tooShort: string;
        passwordShow: string;
        passwordHide: string;
        passwordShowAria: string;
        passwordHideAria: string;
        errorMessages?: Record<string, string>;
      }

      const form = document.getElementById(
        "reset-form"
      ) as HTMLFormElement | null;
      const errorBox = document.getElementById("reset-error");
      const noticeBox = document.getElementById("reset-notice");
      const loginLink = document.getElementById("reset-login-link");
      const submitButton = document.getElementById(
        "reset-submit"
      ) as HTMLButtonElement | null;
      const strings = readClientStrings<ResetStrings>();

      wirePasswordToggle("new-password", "new-password-toggle", strings);

      function reveal(el: HTMLElement | null, message: string): void {
        if (!el) return;
        el.textContent = message;
        el.hidden = false;
        el.classList.remove("auth-banner--enter");
        void el.offsetWidth;
        el.classList.add("auth-banner--enter");
      }

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!submitButton || submitButton.disabled) return;
        if (errorBox) errorBox.hidden = true;

        const formData = new FormData(form);
        const token = String(formData.get("token") ?? "");
        const tenantId = String(formData.get("tenantId") ?? "").trim();
        const newPassword = String(formData.get("newPassword") ?? "");
        const confirmPassword = String(formData.get("confirmPassword") ?? "");

        // Client-side guards (the server re-validates; these are UX only).
        if (newPassword.length < 8) {
          reveal(errorBox, strings.tooShort);
          return;
        }
        if (newPassword !== confirmPassword) {
          reveal(errorBox, strings.mismatch);
          return;
        }

        const unlock = lockElement(submitButton, strings.pleaseWait);

        try {
          const response = await fetch("/api/v1/auth/password/reset", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-AWCMS-Micro-Tenant-ID": tenantId
            },
            credentials: "same-origin",
            body: JSON.stringify({ token, newPassword })
          });

          const payload = await response.json().catch(() => null);

          if (!response.ok || !payload || payload.success !== true) {
            const code = payload?.error?.code as string | undefined;
            const localized = code ? strings.errorMessages?.[code] : null;
            reveal(errorBox, localized ?? strings.genericError);
            unlock();
            return;
          }

          // Done — hide the form, confirm, and offer a route to sign in.
          form.hidden = true;
          reveal(noticeBox, payload.data?.message ?? "");
          if (loginLink) loginLink.hidden = false;
        } catch {
          reveal(errorBox, strings.networkError);
          unlock();
        }
      });
    </script>
  </body>
</html>
