---
interface Props {
  title?: string;
  body?: string;
  tone?: "info" | "warning" | "success" | "danger";
}

const { title, body, tone = "info" } = Astro.props;

const tones = {
  info: { border: "#2563eb", bg: "#eff6ff" },
  warning: { border: "#d97706", bg: "#fff7ed" },
  success: { border: "#16a34a", bg: "#f0fdf4" },
  danger: { border: "#dc2626", bg: "#fef2f2" },
};
---

<div class="callout" style={`--callout-border:${tones[tone].border};--callout-bg:${tones[tone].bg};`}>
  {title && <h4>{title}</h4>}
  {body && <p>{body}</p>}
</div>

<style>
  .callout {
    margin: 1.5rem 0;
    padding: 1rem 1rem 1rem 1rem;
    border-left: 4px solid var(--callout-border);
    border-radius: 0 8px 8px 0;
    background: var(--callout-bg);
  }

  h4 {
    margin: 0 0 0.35rem;
    font-size: 1rem;
  }

  p {
    margin: 0;
    line-height: 1.6;
  }
</style>
