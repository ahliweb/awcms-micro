  "content": {
    "posts": [
      {
        "id": "introducing-awcms-micro",
        "slug": "introducing-awcms-micro",
        "status": "published",
        "data": {
          "title": "Introducing AWCMS-Micro",
          "excerpt": "Why AWCMS-Micro keeps EmDash core intact while shaping a tighter single-tenant implementation.",
          "content": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "AWCMS-Micro is designed as a practical EmDash implementation that keeps upstream behavior intact while delivering a focused content and governance experience for one production site.",
                  "_key": "post-1"
                }
              ],
              "_key": "post-block-1"
            }
          ]
        },
        "bylines": [
          {
            "byline": "byline-awcms-editorial"
          }
        ]
      },
      {
        "id": "introducing-awcms-micro-id",
        "translationOf": "introducing-awcms-micro",
        "locale": "id",
        "slug": "introducing-awcms-micro",
        "status": "published",
        "data": {
          "title": "Memperkenalkan AWCMS-Micro",
          "excerpt": "Mengapa AWCMS-Micro menjaga core EmDash tetap utuh sambil membentuk implementasi single-tenant yang lebih rapat.",
          "content": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "AWCMS-Micro dirancang sebagai implementasi EmDash yang praktis, menjaga perilaku upstream tetap utuh sambil menghadirkan pengalaman konten dan tata kelola yang terfokus untuk satu situs produksi.",
                  "_key": "post-1-id"
                }
              ],
              "_key": "post-block-1-id"
            }
          ]
        },
        "bylines": [
          {
            "byline": "byline-awcms-editorial"
          }
        ]
      }
    ],
    "news": [
      {
        "id": "admin-workflow-connected",
        "slug": "admin-workflow-connected",
        "status": "published",
        "data": {
          "title": "Public Site Now Mirrors Admin Workflow",
          "summary": "Menus, search, content routes, and site identity are now driven from EmDash-managed data.",
          "content": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Editors can update posts, pages, and site settings from the standard EmDash admin routes and immediately see the results reflected on the public-facing website structure.",
                  "_key": "news-1"
                }
              ],
              "_key": "news-block-1"
            }
          ]
        },
        "bylines": [
          {
            "byline": "byline-awcms-editorial"
          }
        ]
      },
      {
        "id": "admin-workflow-connected-id",
        "translationOf": "admin-workflow-connected",
        "locale": "id",
        "slug": "admin-workflow-connected",
        "status": "published",
        "data": {
          "title": "Situs Publik Kini Mencerminkan Alur Kerja Admin",
          "summary": "Menu, pencarian, route konten, dan identitas situs kini digerakkan dari data yang dikelola EmDash.",
          "content": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Editor dapat memperbarui pos, halaman, dan pengaturan situs dari route admin EmDash standar dan langsung melihat hasilnya tercermin pada struktur situs publik.",
                  "_key": "news-1-id"
                }
              ],
              "_key": "news-block-1-id"
            }
          ]
        },
        "bylines": [
          {
            "byline": "byline-awcms-editorial"
          }
        ]
      }
    ],
    "pages": [
      {
        "id": "about",
        "slug": "about",
        "status": "published",
        "data": {
          "title": "About AWCMS-Micro",
          "content": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "AWCMS-Micro packages a slimmer EmDash website experience, keeps upstream core untouched, and adds only project-level templates, content, and example governance surfaces where needed.",
                  "_key": "about-1"
                }
              ],
              "_key": "about-0"
            }
          ]
        }
      },
      {
        "id": "about-id",
        "translationOf": "about",
        "locale": "id",
        "slug": "about",
        "status": "published",
        "data": {
          "title": "Tentang AWCMS-Micro",
          "content": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "AWCMS-Micro mengemas pengalaman situs EmDash yang lebih ramping, menjaga core upstream tetap utuh, dan hanya menambahkan template tingkat proyek, konten, dan surface tata kelola contoh bila diperlukan.",
                  "_key": "about-1-id"
                }
              ],
              "_key": "about-0-id"
            }
          ]
        }
      },
      {
        "id": "public-site-guide",
        "slug": "public-site-guide",
        "status": "published",
        "data": {
          "title": "Public Site Guide",
          "content": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Use this page as the editable landing guide for visitors. Editors can update the copy from Pages, then promote it into the navigation or homepage spotlights.",
                  "_key": "public-guide-1"
                }
              ],
              "_key": "public-guide-0"
            }
          ]
        }
      },
      {
        "id": "public-site-guide-id",
        "translationOf": "public-site-guide",
        "locale": "id",
        "slug": "public-site-guide",
        "status": "published",
        "data": {
          "title": "Panduan Situs Publik",
          "content": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
                  "text": "Gunakan halaman ini sebagai panduan landing yang bisa diedit untuk pengunjung. Editor dapat memperbarui copy dari Pages lalu mempromosikannya ke navigasi atau sorotan beranda.",
                  "_key": "public-guide-1-id"
                }
              ],
              "_key": "public-guide-0-id"
            }
          ]
        }
      },
      {
        "id": "publishing-workflow",
        "slug": "publishing-workflow",
        "status": "published",
        "data": {
          "title": "Publishing Workflow",
          "content": [
            {
              "_type": "block",
              "style": "normal",
              "children": [
                {
                  "_type": "span",
