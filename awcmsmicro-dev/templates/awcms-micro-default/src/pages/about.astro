---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About the AWCMS-Micro Example">
	<section>
		<h2>About</h2>
		<p>
			This example demonstrates a minimal AWCMS-Micro-compatible template with placeholder page
			content, simple navigation, and a footer that highlights the no-core-modification rule.
		</p>
	</section>

	<section>
		<h2>AWCMS-Micro Conventions</h2>
		<ul>
			<li>Single-tenant-first project structure</li>
			<li>Tenant-ready naming and content boundaries</li>
			<li>EmDash-compatible integration points only</li>
			<li>No modification of EmDash built-in templates or plugins</li>
		</ul>
	</section>
</BaseLayout>
