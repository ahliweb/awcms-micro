---
import { decodeSlug, getEmDashEntry, getSeoMeta, getSiteSettings } from "emdash";
import { Image, PortableText, WidgetArea } from "emdash/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resolveAwcmsMicroSiteIdentity } from "../../utils/site-identity";

function asString(value: unknown) {
	return typeof value === "string" ? value : String(value ?? "");
}

function asImage(value: unknown) {
	return value as any;
}

const slug = decodeSlug(Astro.params.slug);

if (!slug) return Astro.redirect("/404");

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) return Astro.redirect("/404");

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
const { siteTitle } = resolveAwcmsMicroSiteIdentity(await getSiteSettings());
const seo = getSeoMeta(post, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
});
---

<BaseLayout
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	canonical={seo.canonical}
	image={seo.ogImage}
	content={{ collection: "posts", id: asString(post.data.id), slug }}
>
	<section style="display:grid;gap:1rem;grid-template-columns:minmax(0,3fr) minmax(250px,1fr);align-items:start;">
		<article>
			{post.data.featured_image && <div {...post.edit.featured_image}><Image image={asImage(post.data.featured_image)} /></div>}
			<h1 {...post.edit.title}>{post.data.title}</h1>
			<PortableText value={post.data.content} />
		</article>
		<aside>
			<WidgetArea name="sidebar" />
		</aside>
	</section>
</BaseLayout>
