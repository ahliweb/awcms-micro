---
import { getEmDashCollection, getI18nConfig, getSiteSettings } from "emdash";
import { Image } from "emdash/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
import { resolveEntrySlug, toLocalePath } from "../utils/locale-path";
import { getPublicCopy } from "../utils/public-copy";
import { resolveAwcmsMicroSiteIdentity } from "../utils/site-identity";

// Import new homepage components
import HomeHero from "../components/HomeHero.astro";
import HomeCTA from "../components/HomeCTA.astro";

function asImage(value: unknown) {
	return value as any;
}

interface GalleryEntry {
	id: string;
	slug: string;
	status: string;
	locale?: string;
	translationOf?: string;
	data: {
		slug?: string;
		title: string;
		description?: string;
		gallery_type: "photo" | "video" | "mixed";
		layout_variant: "grid" | "masonry" | "carousel" | "slider";
		event_date?: string;
		location?: string;
		featured?: boolean;
		cover_image?: { src: string; alt?: string } | null;
		gallery_items?: Array<{
			type: "image" | "video";
			src: string;
			alt?: string;
			caption?: string;
			poster?: string;
		}>;
	};
}

const [
	{ entries: posts, cacheHint: postsCacheHint },
	{ entries: newsItems, cacheHint: newsCacheHint },
	{ entries: pages, cacheHint: pagesCacheHint },
	{ entries: rawGalleries, cacheHint: galleriesCacheHint },
] = await Promise.all([
	getEmDashCollection("posts", {
		orderBy: { published_at: "desc" },
		limit: 3,
	}),
	getEmDashCollection("news", {
		orderBy: { published_at: "desc" },
		limit: 3,
	}),
	getEmDashCollection("pages", {
		orderBy: { published_at: "desc" },
		limit: 6,
	}),
	getEmDashCollection("galleries", {
		orderBy: { published_at: "desc" },
		limit: 100,
	}),
]);

const galleries = rawGalleries as unknown as GalleryEntry[];

if (Astro.cache?.enabled) {
	Astro.cache.set(postsCacheHint);
	Astro.cache.set(newsCacheHint);
	Astro.cache.set(pagesCacheHint);
	Astro.cache.set(galleriesCacheHint);
}

const { siteTitle, siteTagline } = resolveAwcmsMicroSiteIdentity(await getSiteSettings());
const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;
const localeOptions = {
	defaultLocale,
	locales: i18nConfig?.locales || ["en", "id"],
};
const copy = getPublicCopy(currentLocale);

const spotlightPageSlugs = ["about", "public-site-guide", "publishing-workflow"];
const featuredPages = spotlightPageSlugs
	.map((slug) => pages.find((page) => resolveEntrySlug(page) === slug))
	.filter((page): page is (typeof pages)[number] => Boolean(page));
const publicCounts = [
	{ label: copy.counts.posts, value: posts.length },
	{ label: copy.counts.news, value: newsItems.length },
	{ label: copy.counts.pages, value: pages.length },
	{ label: copy.counts.galleries, value: galleries.length },
];
---

<BaseLayout title={siteTitle} description={siteTagline} showFooterWidgets={false}>
	<!-- Hero Section -->
	<HomeHero />

	<!-- Stats Counter Section -->
	<section class="public-counts">
		{publicCounts.map((item) => (
			<div class="public-counts__card">
				<span class="public-counts__label">{item.label}</span>
				<strong class="public-counts__value">{item.value}</strong>
			</div>
		))}
	</section>

	<!-- Editor spotlights and content spotlights -->
	<section class="admin-spotlights">
		<div class="spotlight-card spotlight-card--welcome">
			<p class="spotlight-kicker">{siteTitle}</p>
			<h2 class="spotlight-title">{siteTagline}</h2>
			<p class="spotlight-copy">{currentLocale.startsWith("id") ? "Selamat datang di website resmi kami. Di sini Anda dapat menemukan artikel terbaru dan pengumuman berita penting yang diperbarui secara langsung dari panel admin." : "Welcome to our official website. Here you can discover our latest articles and news announcements updated directly from our admin panel."}</p>
			<div class="spotlight-actions">
				<a class="btn btn-primary" href={toLocalePath("/posts", currentLocale, localeOptions)} data-astro-prefetch="hover">{currentLocale.startsWith("id") ? "Jelajahi Artikel" : "Browse Articles"}</a>
				<a class="btn btn-secondary" href={toLocalePath("/news", currentLocale, localeOptions)} data-astro-prefetch="hover">{currentLocale.startsWith("id") ? "Baca Berita" : "Read News"}</a>
			</div>
		</div>

		<div class="spotlight-card">
			<p class="spotlight-kicker">{copy.featuredPagesTitle}</p>
			<h2 class="spotlight-title">{copy.publicPagesTitle}</h2>
			<p class="spotlight-copy">{copy.publicPagesDescription}</p>
			<div class="spotlight-list">
				{featuredPages.length === 0 ? <p class="no-content-msg">{copy.noPostsCreateOne}</p> : (
					featuredPages.map((page) => (
						<a class="spotlight-list-item" href={toLocalePath(`/${resolveEntrySlug(page)}`, currentLocale, localeOptions)} data-astro-prefetch="hover">
							<span class="spotlight-list-item__title">{page.data.title}</span>
							<span class="spotlight-list-item__meta">/{resolveEntrySlug(page)}</span>
						</a>
					))
				)}
			</div>
			<a class="spotlight-admin-link" href="/_emdash/admin/content/pages">{copy.managePagesInAdmin}</a>
		</div>

	</section>

	<!-- Recent Content Grid (Posts & News) -->
	<div class="recent-content-grid">
		<section class="content-column">
			<h2 class="content-column-title">{copy.recentPosts}</h2>
			{posts.length === 0 ? <p class="no-content-msg">{copy.noPostsCreateOne}</p> : (
				<div class="content-cards">
					{posts.map((post) => (
						<div class="content-card">
							<a class="content-card-link" href={toLocalePath(`/posts/${resolveEntrySlug(post)}`, currentLocale, localeOptions)} data-astro-prefetch="hover">
								{post.data.featured_image && <Image image={asImage(post.data.featured_image)} class="content-card-img" />}
								<h3 class="content-card-title">{post.data.title}</h3>
							</a>
							{post.data.excerpt && <p class="content-card-desc">{post.data.excerpt}</p>}
						</div>
					))}
				</div>
			)}
		</section>

		<section class="content-column">
			<h2 class="content-column-title">{copy.latestNews}</h2>
			{newsItems.length === 0 ? <p class="no-content-msg">{copy.noNewsYet}</p> : (
				<div class="content-cards">
					{newsItems.map((item) => (
						<div class="content-card">
							<a class="content-card-link" href={toLocalePath(`/news/${resolveEntrySlug(item)}`, currentLocale, localeOptions)} data-astro-prefetch="hover">
								<h3 class="content-card-title">{item.data.title}</h3>
							</a>
							{item.data.summary && <p class="content-card-desc">{item.data.summary}</p>}
						</div>
					))}
				</div>
			)}
		</section>
	</div>

	<!-- Recent Galleries Section -->
	<section class="recent-galleries-section">
		<div class="recent-galleries-header">
			<div class="recent-galleries-header__title-group">
				<p class="recent-galleries-kicker">{copy.galleryKicker}</p>
				<h2 class="recent-galleries-title">{copy.featuredGalleryTitle}</h2>
			</div>
			<a href={toLocalePath("/gallery", currentLocale, localeOptions)} class="btn btn-secondary btn-sm" data-astro-prefetch="hover">
				{copy.galleryViewAll} &rarr;
			</a>
		</div>

		{galleries.length === 0 ? (
			<p class="no-content-msg">{copy.noGalleryYet}</p>
		) : (
			<div class="recent-galleries-grid">
				{galleries.slice(0, 3).map((gallery) => {
					const items = gallery.data.gallery_items;
					const count = Array.isArray(items) ? items.length : 0;
					return (
						<a href={toLocalePath(`/gallery/${resolveEntrySlug(gallery)}`, currentLocale, localeOptions)} class="recent-gallery-card" data-astro-prefetch="hover">
							<div class="recent-gallery-card__cover">
								{gallery.data.cover_image ? (
									<Image image={asImage(gallery.data.cover_image)} class="recent-gallery-card__img" alt={gallery.data.title || "Gallery"} />
								) : (
									<div class="recent-gallery-card__placeholder">
										{gallery.data.gallery_type === "video" ? "🎬" : "🖼️"}
									</div>
								)}
								<span class="recent-gallery-card__count-badge">{copy.galleryItemsCount(count)}</span>
							</div>
							<div class="recent-gallery-card__body">
								<h3 class="recent-gallery-card__title">{gallery.data.title}</h3>
								{gallery.data.description && <p class="recent-gallery-card__desc">{gallery.data.description}</p>}
							</div>
						</a>
					);
				})}
			</div>
		)}
	</section>

	<!-- Call to Action Banner -->
	<HomeCTA />
</BaseLayout>

<style>
	.admin-spotlights {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.5rem;
		margin-bottom: 2.5rem;
	}

	.spotlight-card {
		background: var(--gradient-surface);
		border: 1px solid var(--surface-border);
		border-radius: 1.5rem;
		padding: 1.5rem;
		box-shadow: var(--shadow-md);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}

	.spotlight-card--welcome {
		grid-column: span 1;
	}

	.public-counts {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
		gap: 1rem;
		margin: 0 0 2.5rem;
	}

	.public-counts__card {
		padding: 1rem 1.2rem;
		border-radius: 1rem;
		border: 1px solid var(--surface-border);
		background: var(--surface-main);
		box-shadow: var(--shadow-sm);
	}

	.public-counts__label {
		display: block;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 0.4rem;
	}

	.public-counts__value {
		font-size: 2rem;
		line-height: 1;
		font-weight: 800;
		color: var(--text-main);
	}

	.spotlight-kicker {
		margin: 0 0 0.6rem;
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--accent);
	}

	.spotlight-title {
		font-size: 1.4rem;
		font-weight: 800;
		margin: 0 0 0.75rem;
		line-height: 1.2;
	}

	.spotlight-copy {
		margin: 0 0 1.25rem;
		color: var(--text-muted);
		line-height: 1.6;
	}

	.spotlight-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.spotlight-list {
		display: grid;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.spotlight-list-item {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.9rem 1rem;
		border-radius: 1rem;
		border: 1px solid var(--surface-border);
		background: var(--surface-main);
		text-decoration: none;
		color: var(--text-main);
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
	}

	.spotlight-list-item:hover {
		transform: translateY(-2px);
		border-color: rgba(99, 102, 241, 0.3);
		box-shadow: var(--shadow-sm);
	}

	.spotlight-list-item__title {
		font-weight: 700;
	}

	.spotlight-list-item__meta {
		color: var(--text-muted);
		font-size: 0.85rem;
		flex-shrink: 0;
	}

	.spotlight-admin-link {
		display: inline-flex;
		margin-top: 0.25rem;
		font-weight: 700;
		color: var(--accent);
		text-decoration: none;
	}

	@media (max-width: 768px) {
		.spotlight-list-item {
			flex-direction: column;
		}
	}

	.recent-content-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		margin-bottom: 4rem;
	}

	@media (max-width: 768px) {
		.recent-content-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
	}

	.content-column {
		background: var(--gradient-surface);
		border: 1px solid var(--surface-border);
		border-radius: 1.5rem;
		padding: 2.25rem 2rem;
		box-shadow: var(--shadow-md);
		margin-block-end: 0;
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}

	.content-column-title {
		font-size: 1.5rem;
		font-weight: 800;
		color: var(--text-main);
		margin: 0 0 1.5rem;
		border-bottom: 1px solid var(--surface-border);
		padding-bottom: 0.75rem;
		letter-spacing: -0.01em;
	}

	.content-cards {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.content-card {
		background: var(--surface-main);
		border: 1px solid var(--surface-border);
		border-radius: 1rem;
		padding: 1.25rem;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.content-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-md);
		border-color: rgba(99, 102, 241, 0.3);
	}

	.content-card-link {
		color: var(--text-main);
		text-decoration: none;
		display: block;
	}

	.content-card-link:hover {
		color: var(--accent);
		text-shadow: none;
	}

	.content-card-title {
		font-size: 1.15rem;
		font-weight: 700;
		margin: 0 0 0.5rem;
		line-height: 1.3;
	}

	.content-card-desc {
		font-size: 0.9rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.5;
	}

	.content-card-img {
		width: 100%;
		height: auto;
		border-radius: 0.5rem;
		margin-bottom: 0.75rem;
		display: block;
	}

	.no-content-msg {
		font-size: 0.95rem;
		color: var(--text-muted);
		margin: 0;
	}

	/* Recent Galleries Section */
	.recent-galleries-section {
		margin-bottom: 4rem;
	}

	.recent-galleries-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		margin-bottom: 1.75rem;
		border-bottom: 1px solid var(--surface-border);
		padding-bottom: 0.75rem;
	}

	.recent-galleries-kicker {
		margin: 0 0 0.4rem;
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--accent);
	}

	.recent-galleries-title {
		font-size: 1.5rem;
		font-weight: 800;
		color: var(--text-main);
		margin: 0;
		letter-spacing: -0.01em;
	}

	.recent-galleries-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.5rem;
	}

	.recent-gallery-card {
		display: flex;
		flex-direction: column;
		background: var(--gradient-surface);
		border: 1px solid var(--surface-border);
		border-radius: 1.25rem;
		overflow: hidden;
		text-decoration: none;
		color: var(--text-main);
		box-shadow: var(--shadow-sm);
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.recent-gallery-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-md);
		border-color: rgba(99, 102, 241, 0.3);
	}

	.recent-gallery-card__cover {
		position: relative;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: linear-gradient(135deg, rgba(99,102,241,0.05), rgba(217,70,239,0.05));
	}

	.recent-gallery-card__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.4s ease;
	}

	.recent-gallery-card:hover .recent-gallery-card__img {
		transform: scale(1.04);
	}

	.recent-gallery-card__placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2.5rem;
		opacity: 0.5;
	}

	.recent-gallery-card__count-badge {
		position: absolute;
		bottom: 0.75rem;
		right: 0.75rem;
		background: rgba(0, 0, 0, 0.7);
		color: #ffffff;
		padding: 0.2rem 0.5rem;
		border-radius: 0.375rem;
		font-size: 0.75rem;
		font-weight: 600;
	}

	.recent-gallery-card__body {
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.recent-gallery-card__title {
		font-size: 1.1rem;
		font-weight: 700;
		margin: 0;
		line-height: 1.3;
	}

	.recent-gallery-card:hover .recent-gallery-card__title {
		color: var(--accent);
	}

	.recent-gallery-card__desc {
		font-size: 0.85rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
