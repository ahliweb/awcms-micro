---
import { getEmDashCollection, getI18nConfig } from "emdash";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GalleryCard from "../../components/GalleryCard.astro";
import GalleryFilters from "../../components/GalleryFilters.astro";
import { resolveEntrySlug, toLocalePath } from "../../utils/locale-path";
import { getGalleryCopy } from "../../utils/gallery-copy";

function asString(value: unknown, fallback = "") {
	return typeof value === "string" ? value : fallback;
}

const activeType = Astro.url.searchParams.get("type") ?? "all";
const { entries: galleries, cacheHint } = await getEmDashCollection("galleries", {
	orderBy: { published_at: "desc" },
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const visibleGalleries = activeType === "all" ? galleries : galleries.filter((gallery) => gallery.data.gallery_type === activeType);
const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;
const localeOptions = {
	defaultLocale,
	locales: i18nConfig?.locales || ["en", "id"],
};
const copy = getGalleryCopy(currentLocale);
---

<BaseLayout title={copy.pageTitle} description={copy.pageDescription} showFooterWidgets={false}>
	<section>
		<p class="kicker">{copy.pageKicker}</p>
		<h1>{copy.pageHeading}</h1>
		<p>{copy.pageIntro}</p>
		<GalleryFilters activeType={activeType} />
		{visibleGalleries.length === 0 ? <p>{copy.noGalleries}</p> : (
			<div class="gallery-index-grid">
				{visibleGalleries.map((gallery) => (
					<GalleryCard
						href={toLocalePath(`/gallery/${resolveEntrySlug(gallery)}`, currentLocale, localeOptions)}
						title={asString(gallery.data.title, gallery.id)}
						description={asString(gallery.data.description)}
						cover={gallery.data.cover_image as any}
						type={asString(gallery.data.gallery_type)}
						location={asString(gallery.data.location)}
						date={asString(gallery.data.event_date)}
						featured={gallery.data.featured === true}
					/>
				))}
			</div>
		)}
	</section>
</BaseLayout>

<style>
	.gallery-index-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
		gap: 1rem;
	}
</style>
