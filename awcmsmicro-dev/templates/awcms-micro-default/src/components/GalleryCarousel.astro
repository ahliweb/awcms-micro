---
import GalleryVideo from "./GalleryVideo.astro";

interface GalleryItem {
	type?: string;
	src?: string;
	alt?: string;
	caption?: string;
	poster?: string;
	mimeType?: string;
}

interface Props {
	items: GalleryItem[];
}

const { items } = Astro.props;
---

<div class="gallery-carousel" aria-label="Gallery carousel">
	{items.map((item) => item.src && (
		<div class="gallery-carousel__slide">
			{item.type === "video" ? <GalleryVideo src={item.src} caption={item.caption} poster={item.poster} mimeType={item.mimeType} /> : (
				<figure>
					<img src={item.src} alt={item.alt || item.caption || "Gallery image"} loading="lazy" />
					{item.caption && <figcaption>{item.caption}</figcaption>}
				</figure>
			)}
		</div>
	))}
</div>

<style>
	.gallery-carousel {
		display: grid;
		grid-auto-flow: column;
		grid-auto-columns: minmax(18rem, 72%);
		gap: 1rem;
		overflow-x: auto;
		scroll-snap-type: x mandatory;
		padding-bottom: 0.75rem;
	}

	.gallery-carousel__slide {
		scroll-snap-align: start;
	}

	.gallery-carousel figure {
		margin: 0;
	}

	.gallery-carousel img {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: 1rem;
	}

	.gallery-carousel figcaption {
		margin-top: 0.45rem;
		color: var(--text-muted);
	}
</style>
