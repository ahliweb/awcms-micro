---
interface GalleryItem {
	type?: string;
	src?: string;
	alt?: string;
	caption?: string;
}

interface Props {
	items: GalleryItem[];
}

const { items } = Astro.props;
---

<div class="gallery-lightbox" aria-label="Gallery media shortcuts">
	{items.map((item, index) => item.src && (
		<a href={item.src} class="gallery-lightbox__link">
			<span>{index + 1}</span>
			{item.caption || item.alt || item.type || "Media item"}
		</a>
	))}
</div>

<style>
	.gallery-lightbox {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		margin-block: 1rem;
	}

	.gallery-lightbox__link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.35rem 0.65rem;
		border: 1px solid var(--surface-border);
		border-radius: 999px;
		color: var(--text-main);
		font-size: 0.88rem;
	}

	.gallery-lightbox__link span {
		display: inline-grid;
		place-items: center;
		width: 1.35rem;
		height: 1.35rem;
		border-radius: 999px;
		background: var(--accent);
		color: white;
		font-size: 0.75rem;
	}
</style>
