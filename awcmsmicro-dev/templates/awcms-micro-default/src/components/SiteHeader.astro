---
import { getSiteSettings, getI18nConfig } from "emdash";
import { resolveAwcmsMicroSiteIdentity } from "../utils/site-identity";
import { getPublicCopy } from "../utils/public-copy";
import { toLocalePath } from "../utils/locale-path";
import PublicNavigation from "./PublicNavigation.astro";
import LanguageSwitcher from "./public/LanguageSwitcher.astro";
import LiveSearch from "emdash/ui/search";

interface Props {
	content?: { collection: string; id: string; slug?: string | null };
}

const { content } = Astro.props;
const { siteTitle, siteLogo } = resolveAwcmsMicroSiteIdentity(await getSiteSettings());
const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;
const localeOptions = {
	defaultLocale,
	locales: i18nConfig?.locales || ["en", "id"],
};
const copy = getPublicCopy(currentLocale);
---

<header class="site-header-nav">
	<div class="nav-container">
		<a class="nav-brand" href={toLocalePath("/", currentLocale, localeOptions)} data-astro-prefetch="hover">
			{siteLogo ? <img src={siteLogo.url} alt={siteLogo.alt || siteTitle} class="brand-logo" /> : <span class="brand-text">{siteTitle}</span>}
		</a>

		<input type="checkbox" id="menu-toggle" class="menu-toggle-checkbox" />
		<label for="menu-toggle" class="menu-toggle-label" aria-label="Toggle menu">
			<span class="hamburger-bar"></span>
			<span class="hamburger-bar"></span>
			<span class="hamburger-bar"></span>
		</label>

		<div class="nav-menu">
			<div class="nav-center">
				<PublicNavigation name="primary" />
			</div>
			
			<div class="nav-right">
				<div class="header-search">
					<LiveSearch placeholder={copy.searchPlaceholder} collections={["posts", "pages", "news"]} />
				</div>
				<div class="nav-actions">
					<LanguageSwitcher content={content} />
					<a href="/_emdash/admin/login?redirect=/_emdash/admin" class="admin-login-btn">{copy.adminLink}</a>
					<button id="theme-toggle" aria-label={copy.toggleTheme} class="theme-toggle-btn">
						<span class="dark-icon" style="display:none;" title={copy.switchToLightMode}>🌙</span>
						<span class="light-icon" style="display:none;" title={copy.switchToDarkMode}>☀️</span>
					</button>
				</div>
			</div>
		</div>
	</div>
</header>

<style is:global>
	/* Make sure live search input in header looks modern */
	.site-header-nav .emdash-live-search {
		position: relative;
		width: 100%;
		max-width: 240px;
	}
	.site-header-nav .emdash-live-search-input {
		width: 100%;
		font-size: 0.875rem;
		padding: 0.5rem 1rem 0.5rem 2.25rem;
		border-radius: 999px;
		background: rgba(14, 165, 233, 0.05);
		border: 1px solid var(--surface-border);
		transition: all 0.25s ease;
	}
	.site-header-nav .emdash-live-search-input:focus {
		background: var(--bg-main);
		border-color: var(--accent);
		box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.15);
		outline: none;
	}
	.site-header-nav .emdash-live-search-results {
		top: calc(100% + 8px) !important;
		border-radius: 1rem !important;
		border: 1px solid var(--surface-border) !important;
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15) !important;
		background: var(--bg-main) !important;
	}
</style>

<style>
	.site-header-nav {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom: 1px solid var(--surface-border);
		transition: background-color 0.3s ease, border-color 0.3s ease;
	}

	:root.dark .site-header-nav {
		background: rgba(10, 14, 23, 0.85);
	}

	.nav-container {
		max-width: 72rem;
		margin: 0 auto;
		padding: 1rem 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		position: relative;
	}

	.nav-brand {
		display: flex;
		align-items: center;
		text-decoration: none;
		flex-shrink: 0;
	}

	.brand-logo {
		height: 38px;
		width: auto;
		display: block;
	}

	.brand-text {
		font-weight: 800;
		font-size: 1.25rem;
		background: var(--gradient-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		letter-spacing: -0.01em;
	}

	.menu-toggle-checkbox {
		display: none;
	}

	.menu-toggle-label {
		display: none;
		flex-direction: column;
		justify-content: space-between;
		width: 22px;
		height: 16px;
		cursor: pointer;
		z-index: 110;
	}

	.hamburger-bar {
		width: 100%;
		height: 2px;
		background-color: var(--text-main);
		border-radius: 2px;
		transition: all 0.3s ease;
	}

	.nav-menu {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-grow: 1;
		margin-left: 2rem;
	}

	.nav-center {
		display: flex;
		align-items: center;
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		margin-left: auto;
	}

	.header-search {
		display: flex;
		align-items: center;
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.admin-login-btn {
		font-size: 0.875rem;
		font-weight: 700;
		color: var(--text-main);
		background: rgba(14, 165, 233, 0.08);
		border: 1px solid var(--surface-border);
		padding: 0.45rem 1rem;
		border-radius: 999px;
		transition: all 0.25s ease;
		text-decoration: none;
	}

	.admin-login-btn:hover {
		background: var(--accent);
		color: #ffffff;
		border-color: transparent;
		box-shadow: 0 4px 12px rgba(14, 165, 233, 0.2);
	}

	.theme-toggle-btn {
		padding: 0.4rem;
		font-size: 1.2rem;
		background: transparent;
		border: none;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		transition: background-color 0.2s ease;
	}

	.theme-toggle-btn:hover {
		background: var(--surface-border);
	}

	@media (max-width: 991px) {
		.menu-toggle-label {
			display: flex;
		}

		.nav-menu {
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			background: var(--bg-main);
			border-bottom: 1px solid var(--surface-border);
			padding: 1.5rem 1.25rem;
			flex-direction: column;
			align-items: stretch;
			gap: 1.5rem;
			margin-left: 0;
			display: none;
			box-shadow: 0 10px 20px rgba(0,0,0,0.05);
			backdrop-filter: blur(16px);
		}

		.menu-toggle-checkbox:checked ~ .nav-menu {
			display: flex;
		}

		.menu-toggle-checkbox:checked ~ .menu-toggle-label .hamburger-bar:nth-child(1) {
			transform: translateY(7px) rotate(45deg);
		}

		.menu-toggle-checkbox:checked ~ .menu-toggle-label .hamburger-bar:nth-child(2) {
			opacity: 0;
		}

		.menu-toggle-checkbox:checked ~ .menu-toggle-label .hamburger-bar:nth-child(3) {
			transform: translateY(-7px) rotate(-45deg);
		}

		.nav-right {
			flex-direction: column;
			align-items: stretch;
			width: 100%;
			margin-left: 0;
			gap: 1rem;
		}

		.header-search {
			width: 100%;
		}
		
		.site-header-nav .emdash-live-search {
			max-width: none;
		}

		.nav-actions {
			justify-content: space-between;
			width: 100%;
		}
	}
</style>
