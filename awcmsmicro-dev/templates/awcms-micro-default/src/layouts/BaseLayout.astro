---
import { getSiteSettings } from "emdash";
import { createPublicPageContext } from "emdash/page";
import { EmDashBodyEnd, EmDashBodyStart, EmDashHead, WidgetArea } from "emdash/ui";
import LiveSearch from "emdash/ui/search";
import PublicNavigation from "../components/PublicNavigation.astro";
import { resolveAwcmsMicroSiteIdentity } from "../utils/site-identity";

interface Props {
	title: string;
	pageTitle?: string | null;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
}

const { title, pageTitle, description, image, canonical, content } = Astro.props;
const { siteTitle, siteTagline, siteLogo } = resolveAwcmsMicroSiteIdentity(await getSiteSettings());
const fullTitle = title.includes(siteTitle) ? title : `${title} | ${siteTitle}`;
const pageDescription = description ?? siteTagline;
const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: content?.collection === "news" ? "news" : "website",
	title: fullTitle,
	pageTitle: pageTitle ?? title,
	description: pageDescription,
	canonical,
	image,
	content,
	siteName: siteTitle,
});
---

<!doctype html>
	<html lang="en">
		<head>
			<meta charset="utf-8" />
			<meta name="viewport" content="width=device-width, initial-scale=1" />
			<title>{fullTitle}</title>
			{pageDescription && <meta name="description" content={pageDescription} />}
			{canonical && <link rel="canonical" href={canonical} />}
			<EmDashHead page={pageCtx} />
			<style>
				:root {
					color-scheme: light;
					font-family: Inter, system-ui, sans-serif;
					background: #f4f7fb;
					color: #0f172a;
				}

				body {
					margin: 0;
					background:
						radial-gradient(circle at top, rgba(56, 189, 248, 0.14), transparent 28%),
						linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
				}

				a {
					color: #0f766e;
					text-decoration: none;
				}

				a:hover {
					text-decoration: underline;
				}

				.header,
				.main,
				.footer {
					max-width: 72rem;
					margin: 0 auto;
					padding-inline: 1.25rem;
				}

				.header {
					padding-top: 1.5rem;
					padding-bottom: 1rem;
				}

				.nav {
					display: flex;
					justify-content: space-between;
					align-items: center;
					gap: 1rem;
					flex-wrap: wrap;
				}

				.utility-links {
					display: flex;
					gap: 0.75rem;
					flex-wrap: wrap;
					justify-content: flex-end;
					align-items: center;
				}

				.primary-nav-shell {
					margin-top: 1rem;
				}

				.brand {
					font-weight: 800;
					font-size: 1.05rem;
					color: inherit;
				}

				.search-shell {
					margin-top: 1rem;
					max-width: 28rem;
				}

				main {
					padding-block: 1rem 4rem;
				}

				section {
					background: #ffffff;
					border: 1px solid rgba(15, 23, 42, 0.08);
					border-radius: 1.25rem;
					padding: 1.5rem;
					margin-block-end: 1.5rem;
					box-shadow: 0 22px 44px rgba(15, 23, 42, 0.06);
				}

			h1,
			h2 {
				line-height: 1.1;
			}

				p,
				li {
					line-height: 1.7;
				}

				.kicker {
					margin: 0 0 0.65rem;
					text-transform: uppercase;
					letter-spacing: 0.08em;
					font-size: 0.8rem;
					color: #0f766e;
					font-weight: 700;
				}

				.button-link {
					display: inline-flex;
					align-items: center;
					justify-content: center;
					padding: 0.72rem 1rem;
					border-radius: 999px;
					font-weight: 700;
					border: 1px solid rgba(15, 23, 42, 0.12);
					background: #ffffff;
					color: #0f172a;
				}

				.button-link.primary {
					background: linear-gradient(135deg, #0f766e, #0284c7);
					border-color: transparent;
					color: #f8fafc;
				}

				.footer {
					padding-bottom: 3rem;
					color: #475569;
				}

				.footer-card {
					background: rgba(255, 255, 255, 0.9);
					border: 1px solid rgba(15, 23, 42, 0.08);
					border-radius: 1rem;
					padding: 1rem 1.25rem;
				}
			</style>
		</head>
		<body>
			<EmDashBodyStart page={pageCtx} />
			<header class="header">
				<nav class="nav" aria-label="Utility navigation">
					<a class="brand" href="/">
						{siteLogo ? <img src={siteLogo.url} alt={siteLogo.alt || siteTitle} style="height:44px;width:auto;display:block;" /> : siteTitle}
					</a>
					<div class="utility-links">
						<a href="/_emdash/admin/login?redirect=/_emdash/admin">Admin</a>
					</div>
				</nav>
				<div class="primary-nav-shell">
					<PublicNavigation name="primary" />
				</div>
				<div class="search-shell">
					<LiveSearch placeholder="Search posts, pages, and news" collections={["posts", "pages", "news"]} />
				</div>
			</header>
			<main class="main">
				<slot />
			</main>
			<footer class="footer">
				<div class="footer-card">
					<p style="margin-top:0;">{siteTagline}</p>
					<WidgetArea name="sidebar" />
				</div>
			</footer>
			<EmDashBodyEnd page={pageCtx} />
		</body>
	</html>
