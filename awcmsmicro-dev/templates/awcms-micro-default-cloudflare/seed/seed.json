	"content": {
		"pages": [
			{
				"id": "about",
				"slug": "about",
				"status": "published",
				"data": {
					"title": "About AWCMS-Micro",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "AWCMS-Micro combines a public Astro website, protected EmDash admin operations, and Cloudflare deployment primitives without forking or patching EmDash core.",
									"_key": "p1"
								}
							],
							"_key": "b1"
						}
					]
				},
				"bylines": [
					{
						"byline": "byline-awcms-editorial"
					}
				]
			},
			{
				"id": "about-id",
				"translationOf": "about",
				"locale": "id",
				"slug": "about",
				"status": "published",
				"data": {
					"title": "Tentang AWCMS-Micro",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "AWCMS-Micro menggabungkan situs Astro publik, operasi admin EmDash yang terlindungi, dan primitive deployment Cloudflare tanpa melakukan fork atau patch pada core EmDash.",
									"_key": "p1-id"
								}
							],
							"_key": "b1-id"
						}
					]
				}
			},
			{
				"id": "public-site-guide",
				"slug": "public-site-guide",
				"status": "published",
				"data": {
					"title": "Public Site Guide",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Use this page as the editable landing guide for visitors. Editors can update the copy from Pages, then promote it into the navigation or homepage spotlights.",
									"_key": "public-guide-1"
								}
							],
							"_key": "public-guide-0"
						}
					]
				}
			},
			{
				"id": "public-site-guide-id",
				"translationOf": "public-site-guide",
				"locale": "id",
				"slug": "public-site-guide",
				"status": "published",
				"data": {
					"title": "Panduan Situs Publik",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Gunakan halaman ini sebagai panduan landing yang bisa diedit untuk pengunjung. Editor dapat memperbarui copy dari Pages lalu mempromosikannya ke navigasi atau sorotan beranda.",
									"_key": "public-guide-1-id"
								}
							],
							"_key": "public-guide-0-id"
						}
					]
				}
			},
			{
				"id": "publishing-workflow",
				"slug": "publishing-workflow",
				"status": "published",
				"data": {
					"title": "Publishing Workflow",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
