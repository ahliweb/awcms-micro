{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "awcms-micro-default-cloudflare",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-05-14",
	"compatibility_flags": ["nodejs_compat"],
	"placement": { "mode": "smart" },
	"routes": [
		{
			"pattern": "awcms-micro.ahlikoding.com",
			"zone_name": "ahlikoding.com",
			"custom_domain": true
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "awcms-micro-d1"
		}
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "awcms-micro-media"
		}
	],
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "REPLACE_WITH_AWCMS_MICRO_SESSION_NAMESPACE_ID"
		}
	],
	"images": {
		"binding": "IMAGES"
	},
	"worker_loaders": [
		{
			"binding": "LOADER"
		}
	],
	"vars": {
		"AWCMS_MICRO_SITE_URL": "https://awcms-micro.ahlikoding.com",
		"AWCMS_MICRO_STORAGE_PUBLIC_BASE_URL": "https://awcms-micro-s3.ahlikoding.com"
	},
	"observability": {
		"enabled": true
	}
}
