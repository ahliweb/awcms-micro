---
import { getI18nConfig } from "emdash";
import Base from "../layouts/Base.astro";
import { toLocalePath } from "../utils/locale-path";

const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;
const localeOptions = {
	defaultLocale,
	locales: i18nConfig?.locales || ["en", "id"],
};
---

<Base title="Not Found" description="The requested page could not be found." showFooterWidgets={false}>
	<div class="card">
		<h1>Not Found</h1>
		<p>The requested page does not exist in this AWCMS-Micro Cloudflare example.</p>
		<p><a href={toLocalePath("/", currentLocale, localeOptions)} data-astro-prefetch="hover">Return home</a></p>
	</div>
</Base>
