---
import { getEmDashCollection, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import { resolveAwcmsMicroSiteIdentity } from "../utils/site-identity";

const [{ entries: posts, cacheHint: postsCacheHint }, { entries: newsItems, cacheHint: newsCacheHint }, { entries: pages, cacheHint: pagesCacheHint }] = await Promise.all([
	getEmDashCollection("posts", { limit: 100 }),
	getEmDashCollection("news", { limit: 100 }),
	getEmDashCollection("pages", { limit: 100 }),
]);

if (Astro.cache?.enabled) {
	Astro.cache.set(postsCacheHint);
	Astro.cache.set(newsCacheHint);
	Astro.cache.set(pagesCacheHint);
}

const { siteTitle } = resolveAwcmsMicroSiteIdentity(await getSiteSettings());

const counts = [
	{ label: "Posts", value: posts.length },
	{ label: "News", value: newsItems.length },
	{ label: "Pages", value: pages.length },
];
---

<Base title="Public Aggregate" description="A public-safe summary page for the AWCMS-Micro Cloudflare template.">
	<section class="card" style="margin-bottom:2rem;">
		<p class="kicker">Reference</p>
		<h1 style="font-size:clamp(2.25rem,5vw,3.5rem);margin:0 0 1rem;">Public aggregate for {siteTitle}</h1>
		<p style="color:var(--text-muted);margin-bottom:0;">
			This page demonstrates the public-safe aggregate pattern. It exposes only coarse counts and avoids
			sensitive identifiers, raw storage keys, or private registry data.
		</p>
	</section>

	<section class="card" style="margin-bottom:2rem;">
		<h2 style="margin-top:0;">Summary</h2>
		<div style="display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));">
			{counts.map((item) => (
				<div style="border:1px solid rgba(15,23,42,0.08);border-radius:1rem;padding:1rem;background:#fff;">
					<div style="font-size:0.9rem;color:var(--text-muted);">{item.label}</div>
					<div style="font-size:2rem;font-weight:800;line-height:1.1;">{item.value}</div>
				</div>
			))}
		</div>
	</section>

	<section class="card">
		<h2 style="margin-top:0;">Privacy note</h2>
		<p style="color:var(--text-muted);">
			This aggregate stays high level so it can be published without revealing individual registry entities,
			verification events, or protected attributes.
		</p>
		<p style="margin-bottom:0;"><a href="/_emdash/admin">Open admin</a> to work with the underlying content and governance workflows.</p>
	</section>
</Base>
