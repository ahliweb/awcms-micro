---
import { getEmDashCollection, getI18nConfig } from "emdash";
import Base from "../../layouts/Base.astro";
import SectionHeading from "../../components/public/SectionHeading.astro";
import TestimonialCard from "../../components/public/TestimonialCard.astro";
import { getPublicCopy } from "../../utils/public-copy";

interface TestimonialEntry {
	id: string;
	slug: string;
	data: { quote: string; name?: string; role?: string; featured?: boolean; order?: number };
}

const { entries: rawTestimonials, cacheHint } = await getEmDashCollection("testimonials", {
	orderBy: { published_at: "desc" },
	limit: 50,
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;
const copy = getPublicCopy(currentLocale);

const testimonials = (rawTestimonials as unknown as TestimonialEntry[]).sort(
	(a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
);
---

<Base title={copy.testimonialsTitle} description={copy.testimonialsDescription} showFooterWidgets={false}>
	<section class="section-shell">
		<SectionHeading eyebrow={copy.testimonialsKicker} title={copy.testimonialsHeading} subtitle={copy.testimonialsIntro} />
		{testimonials.length === 0 ? (
			<p class="section-subtitle">{copy.testimonialsEmpty}</p>
		) : (
			<div class="public-grid public-grid--3">
				{testimonials.map((item) => (
					<TestimonialCard quote={item.data.quote} name={item.data.name || ""} role={item.data.role} />
				))}
			</div>
		)}
	</section>
</Base>
