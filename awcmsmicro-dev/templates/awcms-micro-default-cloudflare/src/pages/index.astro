---
import { getEmDashCollection, getI18nConfig, getSiteSettings } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { resolveEntrySlug, toLocalePath } from "../utils/locale-path";
import { getPublicCopy } from "../utils/public-copy";
import { resolveAwcmsMicroSiteIdentity } from "../utils/site-identity";

function asImage(value: unknown) {
	return value as any;
}

const [
	{ entries: posts, cacheHint: postsCacheHint },
	{ entries: newsItems, cacheHint: newsCacheHint },
	{ entries: pages, cacheHint: pagesCacheHint },
	{ entries: galleries, cacheHint: galleriesCacheHint },
] = await Promise.all([
	getEmDashCollection("posts", {
		orderBy: { published_at: "desc" },
		limit: 3,
	}),
	getEmDashCollection("news", {
		orderBy: { published_at: "desc" },
		limit: 3,
	}),
	getEmDashCollection("pages", {
		orderBy: { published_at: "desc" },
		limit: 6,
	}),
	getEmDashCollection("galleries", {
		orderBy: { published_at: "desc" },
		limit: 3,
	}),
]);

if (Astro.cache?.enabled) {
	Astro.cache.set(postsCacheHint);
	Astro.cache.set(newsCacheHint);
	Astro.cache.set(pagesCacheHint);
	Astro.cache.set(galleriesCacheHint);
}

const { siteTitle, siteTagline } = resolveAwcmsMicroSiteIdentity(await getSiteSettings());
const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;
const localeOptions = {
	defaultLocale,
	locales: i18nConfig?.locales || ["en", "id"],
};
const copy = getPublicCopy(currentLocale);

const spotlightPageSlugs = ["about", "public-site-guide", "publishing-workflow"];
const featuredPages = spotlightPageSlugs
	.map((slug) => pages.find((page) => resolveEntrySlug(page) === slug))
	.filter((page): page is (typeof pages)[number] => Boolean(page));
const gallerySpotlight = galleries.find((gallery) => gallery.data.featured === true) ?? galleries[0];
const publicCounts = [
	{ label: copy.counts.posts, value: posts.length },
	{ label: copy.counts.news, value: newsItems.length },
	{ label: copy.counts.pages, value: pages.length },
	{ label: copy.counts.galleries, value: galleries.length },
];
---

<Base title={siteTitle} description={siteTagline} showFooterWidgets={false}>
  <section class="card hero-card" style="margin-bottom:2.5rem; text-align: center; padding: 4rem 2rem;">
		<p style="text-transform:uppercase;letter-spacing:0.15em;font-weight:600;color:var(--accent);margin-bottom:1rem;">{copy.homeKicker}</p>
		<h1 style="font-size:clamp(2.5rem,6vw,4rem);line-height:1.1;margin:0 auto 1.5rem;max-width:48rem;font-weight:800;">{copy.homeHeading}</h1>
		<p style="max-width:42rem;margin:0 auto 2.5rem;font-size:1.1rem;color:var(--text-muted);">{copy.homeIntro}</p>
		<div class="hero-actions" style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;">
			<a class="btn btn-primary" style="padding: 1rem 1.75rem; font-size: 1.1rem;" href={toLocalePath("/posts", currentLocale, localeOptions)} data-astro-prefetch="hover">{currentLocale.startsWith("id") ? "Jelajahi Artikel" : "Browse Articles"}</a>
			<a class="btn btn-secondary" style="padding: 1rem 1.75rem; font-size: 1.1rem;" href={toLocalePath("/news", currentLocale, localeOptions)} data-astro-prefetch="hover">{currentLocale.startsWith("id") ? "Baca Berita" : "Read News"}</a>
		</div>
  </section>

	<!-- Stats Counter Section -->
	<section class="stack-grid stack-grid--counts" style="display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));margin-bottom:2rem;">
		{publicCounts.map((item) => (
			<div class="card" style="padding:1rem 1.2rem;">
				<p class="kicker" style="margin-bottom:0.35rem;">{item.label}</p>
				<strong style="font-size:2rem;line-height:1;">{item.value}</strong>
			</div>
		))}
	</section>

	<!-- Welcome & Spotlight Section -->
	<section class="stack-grid" style="display:grid;gap:1.5rem;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));margin-bottom:2rem;">
		<!-- Welcome Card -->
		<div class="card" style="display:flex;flex-direction:column;justify-content:space-between;height:100%;">
			<div>
				<p class="kicker">{siteTitle}</p>
				<h2 style="font-size:1.3rem;margin-top:0;">{siteTagline}</h2>
				<p style="color:var(--text-muted);margin-bottom:1.5rem;line-height:1.6;">
					{currentLocale.startsWith("id") 
						? "Selamat datang di website resmi kami. Di sini Anda dapat menemukan artikel terbaru, pengumuman berita penting, serta galeri kegiatan kami yang diperbarui langsung dari panel admin." 
						: "Welcome to our official website. Discover our latest articles, news announcements, and activity galleries updated directly from the admin panel."}
				</p>
			</div>
			<div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:auto;">
				<a class="btn btn-primary" style="padding:0.75rem 1.25rem;font-size:0.95rem;" href={toLocalePath("/posts", currentLocale, localeOptions)} data-astro-prefetch="hover">
					{currentLocale.startsWith("id") ? "Artikel" : "Articles"}
				</a>
				<a class="btn btn-secondary" style="padding:0.75rem 1.25rem;font-size:0.95rem;" href={toLocalePath("/news", currentLocale, localeOptions)} data-astro-prefetch="hover">
					{currentLocale.startsWith("id") ? "Berita" : "News"}
				</a>
			</div>
		</div>

		<!-- Featured Pages Card -->
		<div class="card" style="display:flex;flex-direction:column;justify-content:space-between;height:100%;">
			<div>
				<p class="kicker">{copy.publicPagesTitle}</p>
				<h2 style="font-size:1.3rem;margin-top:0;">{copy.publicPagesTitle}</h2>
				<p style="color:var(--text-muted);margin-bottom:1.25rem;">{copy.publicPagesDescription}</p>
				<div style="display:grid;gap:0.75rem;margin-bottom:1rem;">
					{featuredPages.length === 0 ? <p style="color:var(--text-muted);margin:0;">{copy.noPostsYet}</p> : (
						featuredPages.map((page) => (
							<a href={toLocalePath(`/${resolveEntrySlug(page)}`, currentLocale, localeOptions)} data-astro-prefetch="hover" style="display:flex;justify-content:space-between;gap:1rem;padding:0.75rem 1rem;border:1px solid var(--surface-border);border-radius:0.75rem;text-decoration:none;color:var(--text-main);background:var(--surface-main);font-size:0.925rem;font-weight:600;transition:all 0.2s ease;">
								<span>{page.data.title}</span>
								<span style="color:var(--text-muted);font-weight:normal;font-size:0.85rem;">/{resolveEntrySlug(page)}</span>
							</a>
						))
					)}
				</div>
			</div>
			<a style="font-weight:700;color:var(--accent);text-decoration:none;font-size:0.95rem;margin-top:auto;" href="/_emdash/admin/content/pages">{copy.managePagesInAdmin}</a>
		</div>

		<!-- Featured Gallery Card -->
		<div class="card" style="display:flex;flex-direction:column;justify-content:space-between;height:100%;">
			<div>
				<p class="kicker">{copy.featuredGalleryTitle}</p>
				<h2 style="font-size:1.3rem;margin-top:0;">{copy.featuredGalleryTitle}</h2>
				<p style="color:var(--text-muted);margin-bottom:1.25rem;">{copy.featuredGalleryDescription}</p>
				{gallerySpotlight ? (
					<a href={toLocalePath(`/gallery/${resolveEntrySlug(gallerySpotlight)}`, currentLocale, localeOptions)} data-astro-prefetch="hover" style="display:grid;gap:0.6rem;text-decoration:none;color:var(--text-main);">
						{gallerySpotlight.data.cover_image && <Image image={asImage(gallerySpotlight.data.cover_image)} style="width:100%;aspect-ratio:16/9;object-fit:cover;border-radius:0.75rem;" />}
						<strong style="font-size:1rem;">{gallerySpotlight.data.title}</strong>
						<p style="margin:0;color:var(--text-muted);font-size:0.875rem;line-height:1.55;">{gallerySpotlight.data.description}</p>
					</a>
				) : <p style="color:var(--text-muted);margin:0;">{copy.noPostsYet}</p>}
			</div>
		</div>
	</section>

	<section style="display:grid;gap:1.5rem;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));">
		<div class="card">
			<h2 style="font-size:1.5rem;margin-top:0;">{copy.recentPosts}</h2>
			{posts.length === 0 ? <p style="color:var(--text-muted);">{copy.noPostsYet}</p> : (
				<ul style="padding-left:1.25rem;color:var(--text-muted);">
					{posts.map((post) => (
						<li style="margin-bottom:1rem;">
							<a href={toLocalePath(`/posts/${resolveEntrySlug(post)}`, currentLocale, localeOptions)} data-astro-prefetch="hover" style="display:block;margin-bottom:0.25rem;font-size:1.1rem;font-weight:500;">
							{post.data.featured_image && <Image image={asImage(post.data.featured_image)} style="border-radius:0.5rem;margin-bottom:0.5rem;width:100%;height:auto;aspect-ratio:16/9;object-fit:cover;" />}
								{post.data.title}
							</a>
							{post.data.excerpt && <p style="margin:0;font-size:0.95rem;">{post.data.excerpt}</p>}
						</li>
					))}
				</ul>
			)}
			<p style="margin-top:1.5rem;"><a class="btn btn-secondary" href={toLocalePath("/posts", currentLocale, localeOptions)} data-astro-prefetch="hover">{copy.browseAllPosts}</a></p>
		</div>

		<div class="card">
			<h2 style="font-size:1.5rem;margin-top:0;">{copy.latestNews}</h2>
			{newsItems.length === 0 ? <p style="color:var(--text-muted);">{copy.noNewsYet}</p> : (
				<ul style="padding-left:1.25rem;color:var(--text-muted);">
					{newsItems.map((item) => (
						<li style="margin-bottom:1rem;">
							<a href={toLocalePath(`/news/${resolveEntrySlug(item)}`, currentLocale, localeOptions)} data-astro-prefetch="hover" style="display:block;margin-bottom:0.25rem;font-size:1.1rem;font-weight:500;">{item.data.title}</a>
							{item.data.summary && <p style="margin:0;font-size:0.95rem;">{item.data.summary}</p>}
						</li>
					))}
				</ul>
			)}
			<p style="margin-top:1.5rem;"><a class="btn btn-secondary" href={toLocalePath("/news", currentLocale, localeOptions)} data-astro-prefetch="hover">{copy.browseAllNews}</a></p>
		</div>

		<div class="card">
			<h2 style="font-size:1.5rem;margin-top:0;">{copy.managedPages}</h2>
			<ul style="padding-left:1.25rem;color:var(--text-muted);">
				{pages.map((page) => (
					<li style="margin-bottom:0.75rem;"><a href={toLocalePath(`/${resolveEntrySlug(page)}`, currentLocale, localeOptions)} data-astro-prefetch="hover" style="font-weight:500;">{page.data.title}</a></li>
				))}
			</ul>
			<p style="margin-top:1.5rem;"><a class="btn btn-secondary" href="/_emdash/admin/content/pages">{copy.managePagesInAdmin}</a></p>
		</div>
	</section>

  <script is:inline>
		const pageThemeToggle = document.getElementById("page-theme-toggle");
		const headerThemeToggle = document.getElementById("theme-toggle");

		if (pageThemeToggle && headerThemeToggle) {
			pageThemeToggle.addEventListener("click", () => headerThemeToggle.click());
		}
  </script>

  <style>
	.stack-grid {
		align-items: stretch;
	}

	.stack-grid :global(.card) {
		height: 100%;
	}

	.hero-actions > .btn {
		min-width: 11rem;
	}

	@media (max-width: 640px) {
		.hero-card {
			padding: 2.5rem 1.25rem !important;
		}

		.hero-actions {
			flex-direction: column;
			align-items: stretch;
		}

		.hero-actions > .btn {
			width: 100%;
			justify-content: center;
			min-width: 0;
		}
	}
  </style>
</Base>
