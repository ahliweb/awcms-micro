---
import { getEmDashCollection, getSiteSettings } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { resolveAwcmsMicroSiteIdentity } from "../utils/site-identity";

function asImage(value: unknown) {
	return value as any;
}

const { entries: posts, cacheHint: postsCacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 3,
});
const { entries: newsItems, cacheHint: newsCacheHint } = await getEmDashCollection("news", {
	orderBy: { published_at: "desc" },
	limit: 3,
});

if (Astro.cache?.enabled) {
	Astro.cache.set(postsCacheHint);
	Astro.cache.set(newsCacheHint);
}

const { siteTitle, siteTagline } = resolveAwcmsMicroSiteIdentity(await getSiteSettings());
---

<Base title={siteTitle} description={siteTagline}>
	<section class="card" style="margin-bottom:1.5rem;">
		<p style="text-transform:uppercase;letter-spacing:0.08em;color:#7dd3fc;">AWCMS-Micro Cloudflare Example</p>
		<h1 style="font-size:clamp(2rem,5vw,3.5rem);margin:0 0 1rem;">A deployable EmDash site prepared for AWCMS-Micro on Cloudflare.</h1>
		<p style="max-width:46rem;line-height:1.6;">
			This example keeps EmDash core untouched while demonstrating a public homepage, posts,
			news, pages, the standard admin route, and the AWCMS-Micro example plugin in a
			Cloudflare-ready template.
		</p>
	</section>

	<section style="display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));margin-bottom:1.5rem;">
		<div class="card">
			<h2>Cloudflare-ready</h2>
			<p>Prepared for D1, R2, Worker Loader, observability, and a custom domain route.</p>
		</div>
		<div class="card">
			<h2>Plugin-enabled</h2>
			<p>Registers <code>@awcms-micro/plugin-example</code> through the normal EmDash plugin path.</p>
		</div>
		<div class="card">
			<h2>Admin included</h2>
			<p>The standard EmDash admin panel remains available at <code>/_emdash/admin</code>.</p>
		</div>
	</section>

	<section style="display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));">
		<div class="card">
			<h2>Recent Posts</h2>
			{posts.length === 0 ? <p>No posts yet.</p> : (
				<ul style="padding-left:1.25rem;">
					{posts.map((post) => (
						<li style="margin-bottom:0.75rem;">
							<a href={`/posts/${post.id}`}>
							{post.data.featured_image && <Image image={asImage(post.data.featured_image)} />}
								<strong>{post.data.title}</strong>
							</a>
							{post.data.excerpt && <p>{post.data.excerpt}</p>}
						</li>
					))}
				</ul>
			)}
			<p><a href="/posts">Browse all posts</a></p>
		</div>

		<div class="card">
			<h2>Latest News</h2>
			{newsItems.length === 0 ? <p>No news yet.</p> : (
				<ul style="padding-left:1.25rem;">
					{newsItems.map((item) => (
						<li style="margin-bottom:0.75rem;">
							<a href={`/news/${item.id}`}><strong>{item.data.title}</strong></a>
							{item.data.summary && <p>{item.data.summary}</p>}
						</li>
					))}
				</ul>
			)}
			<p><a href="/news">Browse all news</a></p>
		</div>
	</section>
</Base>
