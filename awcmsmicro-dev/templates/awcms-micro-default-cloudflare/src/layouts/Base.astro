---
import { getMenu, getSiteSettings } from "emdash";
import { createPublicPageContext } from "emdash/page";
import { EmDashBodyEnd, EmDashBodyStart, EmDashHead, WidgetArea } from "emdash/ui";
import LiveSearch from "emdash/ui/search";
import { resolveAwcmsMicroSiteIdentity } from "../utils/site-identity";

interface Props {
	title: string;
	pageTitle?: string | null;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
}

const { title, pageTitle, description, image, canonical, content } = Astro.props;
const { siteTitle, siteTagline, siteLogo } = resolveAwcmsMicroSiteIdentity(await getSiteSettings());
const fullTitle = title.includes(siteTitle) ? title : `${title} | ${siteTitle}`;
const pageDescription = description ?? siteTagline;
const menu = await getMenu("primary");

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: content?.collection === "news" ? "news" : "website",
	title: fullTitle,
	pageTitle: pageTitle ?? title,
	description: pageDescription,
	canonical,
	image,
	content,
	siteName: siteTitle,
});
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		{pageDescription && <meta name="description" content={pageDescription} />}
		{canonical && <link rel="canonical" href={canonical} />}
		<EmDashHead page={pageCtx} />
		<style>
			:root {
				color-scheme: light dark;
				font-family: Inter, system-ui, sans-serif;
			}

			body {
				margin: 0;
				background: #071019;
				color: #e8eef7;
			}

			a {
				color: #7dd3fc;
				text-decoration: none;
			}

			a:hover {
				text-decoration: underline;
			}

			.header,
			.main,
			.footer {
				max-width: 1100px;
				margin: 0 auto;
				padding-inline: 1.25rem;
			}

			.header {
				padding-top: 1.25rem;
				padding-bottom: 1rem;
			}

			.nav {
				display: flex;
				gap: 1rem;
				align-items: center;
				justify-content: space-between;
				flex-wrap: wrap;
			}

			.nav-links {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
			}

			.brand {
				font-weight: 700;
				font-size: 1.05rem;
			}

			.main {
				padding-block: 1rem 4rem;
			}

			.footer {
				padding-bottom: 3rem;
				color: #9fb1c7;
			}

			.card {
				background: rgba(15, 23, 42, 0.88);
				border: 1px solid rgba(125, 211, 252, 0.15);
				border-radius: 1rem;
				padding: 1rem;
			}
		</style>
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />
		<header class="header">
			<nav class="nav">
				<a class="brand" href="/">
					{siteLogo ? <img src={siteLogo.url} alt={siteLogo.alt || siteTitle} style="height:44px;width:auto;display:block;" /> : siteTitle}
				</a>
				<div class="nav-links">
					{menu?.items.map((item) => <a href={item.url} target={item.target}>{item.label}</a>)}
					<a href="/_emdash/admin/login?redirect=/_emdash/admin">Admin</a>
					<a href="/_emdash/api/plugins/awcms-micro-example/public/status">Plugin Status</a>
				</div>
			</nav>
			<div style="margin-top:1rem;max-width:28rem;">
				<LiveSearch placeholder="Search posts, pages, and news" collections={["posts", "pages", "news"]} />
			</div>
			<div style="margin-top:1rem;display:flex;gap:0.75rem;flex-wrap:wrap;">
				<a class="card" style="padding:0.7rem 0.9rem;display:inline-flex;align-items:center;" href="/_emdash/admin/content/posts/new">Create Post</a>
				<a class="card" style="padding:0.7rem 0.9rem;display:inline-flex;align-items:center;" href="/_emdash/admin/content/pages/new">Create Page</a>
				<a class="card" style="padding:0.7rem 0.9rem;display:inline-flex;align-items:center;" href="/_emdash/admin/plugins/awcms-micro-example/overview">Plugin Overview</a>
			</div>
		</header>

		<main class="main">
			<slot />
		</main>

		<footer class="footer">
			<div class="card">
				<p style="margin-top:0;">{siteTagline}</p>
				<WidgetArea name="sidebar" />
			</div>
		</footer>

		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
