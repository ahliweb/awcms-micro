msgctxt "cloudflareReady"
msgid "Cloudflare-ready"
msgstr "Siap Cloudflare"

msgctxt "cloudflareReadyDescription"
msgid "Ready for D1, R2, Workers, observability, and the `awcms-micro.ahlikoding.com` deployment route."
msgstr "Siap untuk D1, R2, Workers, observability, dan route deployment `awcms-micro.ahlikoding.com`."

msgctxt "pluginEnabled"
msgid "Plugin-enabled"
msgstr "Plugin aktif"

msgctxt "pluginEnabledDescription"
msgid "Registers `@awcms-micro/plugin-sikesra` through the normal EmDash plugin path for audit, access-rights, and ABAC examples."
msgstr "Mendaftarkan `@awcms-micro/plugin-sikesra` melalui jalur plugin EmDash normal untuk contoh audit, hak akses, dan ABAC."

msgctxt "publicAggregateTitle"
msgid "Public aggregate"
msgstr "Agregat publik"

msgctxt "publicAggregateDescription"
msgid "Provides a public-safe summary page that exposes only high-level counts, not private registry details."
msgstr "Menyediakan halaman ringkasan aman-publik yang hanya mengekspos hitungan tingkat tinggi, bukan detail registry privat."

msgctxt "adminProtected"
msgid "Admin protected"
msgstr "Admin terlindungi"

msgctxt "adminProtectedDescription"
msgid "Unauthenticated visits are pushed to `/_emdash/admin/login` before the admin shell renders."
msgstr "Kunjungan tanpa autentikasi diarahkan ke `/_emdash/admin/login` sebelum shell admin dirender."

msgctxt "publishedFromAdmin"
msgid "Published from admin"
msgstr "Dipublikasikan dari admin"

msgctxt "publishedFromAdminDescription"
msgid "Posts, pages, and news created in EmDash are displayed by the public site routes immediately after publish."
msgstr "Pos, halaman, dan berita yang dibuat di EmDash langsung ditampilkan oleh route situs publik setelah publish."

msgctxt "publicSearchAndNavigation"
msgid "Public search and navigation"
msgstr "Pencarian dan navigasi publik"

msgctxt "publicSearchAndNavigationDescription"
msgid "Menus, site identity, and live search are all reading from EmDash-managed content rather than template placeholders."
msgstr "Menu, identitas situs, dan live search semuanya membaca dari konten yang dikelola EmDash, bukan placeholder template."

msgctxt "operationalSurfaces"
msgid "Operational surfaces"
msgstr "Surface operasional"

msgctxt "operationalSurfacesDescription"
msgid "Editors can jump from the public website into content creation, settings, and plugin dashboards without leaving the same deployment."
msgstr "Editor dapat berpindah dari situs publik ke pembuatan konten, pengaturan, dan dasbor plugin tanpa meninggalkan deployment yang sama."

