msgctxt "aggregateTitle"
msgid "Public Aggregate"
msgstr "Agregat Publik"

msgctxt "aggregateDescription"
msgid "A public-safe summary page for the AWCMS-Micro Cloudflare template."
msgstr "Halaman ringkasan aman-publik untuk template Cloudflare AWCMS-Micro."

msgctxt "aggregateKicker"
msgid "Reference"
msgstr "Referensi"

msgctxt "aggregateHeading"
msgid "Public aggregate for {siteTitle}"
msgstr "Agregat publik untuk {siteTitle}"

msgctxt "aggregateIntro"
msgid "This page demonstrates the public-safe aggregate pattern. It exposes only coarse counts and avoids sensitive identifiers, raw storage keys, or private registry data."
msgstr "Halaman ini mendemonstrasikan pola agregat aman-publik. Halaman ini hanya menampilkan hitungan tingkat tinggi dan menghindari pengenal sensitif, kunci storage mentah, atau data registry privat."

msgctxt "summary"
msgid "Summary"
msgstr "Ringkasan"

msgctxt "privacyNote"
msgid "Privacy note"
msgstr "Catatan privasi"

msgctxt "privacyNoteDescription"
msgid "This aggregate stays high level so it can be published without revealing individual registry entities, verification events, or protected attributes."
msgstr "Agregat ini tetap berada pada level tinggi sehingga dapat dipublikasikan tanpa mengungkap entitas registry individual, event verifikasi, atau atribut yang dilindungi."

