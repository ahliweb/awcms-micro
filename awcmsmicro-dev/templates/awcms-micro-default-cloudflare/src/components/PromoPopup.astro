---
import { createWhatsAppUrl, type WebsiteSocialConfig } from "../utils/website-social";

interface Props {
	config: WebsiteSocialConfig;
	copy: {
		promoTriggerLabel: string;
		promoLimitedOffer: string;
		promoTitle: string;
		promoText: string;
		promoPrice: string;
		promoDiscount: string;
		promoCta: string;
		promoCloseLabel: string;
		promoWaMessage: string;
		promoFeature1: string;
		promoFeature2: string;
		promoFeature3: string;
		promoFeature4: string;
	};
}

const { config, copy } = Astro.props;
const promoWaUrl = createWhatsAppUrl(config, copy.promoWaMessage);
---

{config.enabled && config.whatsappNumber && (
	<>
		<button type="button" id="promo-trigger" class="promo-float" aria-controls="promo-popup" aria-expanded="false">
			<svg class="promo-float__icon" xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<polyline points="20 12 20 22 4 22 4 12"/>
				<rect x="2" y="7" width="20" height="5" rx="1"/>
				<line x1="12" y1="22" x2="12" y2="7"/>
				<path d="M12 7H7.5a2.5 2.5 0 1 1 2-4c.75 1 2.5 4 2.5 4Z"/>
				<path d="M12 7h4.5a2.5 2.5 0 1 0-2-4c-.75 1-2.5 4-2.5 4Z"/>
			</svg>
			<span class="promo-float__label">{copy.promoTriggerLabel}</span>
		</button>

		<div id="promo-popup" class="promo-overlay" aria-hidden="true">
			<div class="promo-content" role="dialog" aria-modal="true" aria-labelledby="promo-popup-title">
				<button type="button" id="promo-close" class="promo-close-btn" aria-label={copy.promoCloseLabel}>&times;</button>
				<div class="promo-header">
					<span class="promo-badge">{copy.promoLimitedOffer}</span>
				</div>
				<div class="promo-body">
					<h3 id="promo-popup-title">{copy.promoTitle}</h3>
					<p>{copy.promoText}</p>
					<div class="promo-pricing-box">
						<span class="promo-price-tag">{copy.promoPrice}</span>
						<span class="promo-discount-tag">{copy.promoDiscount}</span>
					</div>
					<ul class="promo-features-list">
						{[copy.promoFeature1, copy.promoFeature2, copy.promoFeature3, copy.promoFeature4].map((feature) => (
							<li>
								<svg class="promo-feature-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<polyline points="20 6 9 17 4 12"/>
								</svg>
								<span>{feature}</span>
							</li>
						))}
					</ul>
					<a id="promo-cta" href={promoWaUrl} target="_blank" rel="noreferrer" class="promo-cta-btn">
						<svg class="icon-whatsapp" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.517 2.266 2.27 3.507 5.289 3.507 8.494-.01 6.66-5.347 11.998-11.957 11.998-1.998-.001-3.957-.502-5.692-1.458L0 24zM6.59 5.92c-.22-.486-.452-.496-.662-.505-.171-.007-.369-.007-.567-.007-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.262.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.496.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207z"/>
						</svg>
						<span>{copy.promoCta}</span>
					</a>
				</div>
			</div>
		</div>

		<script is:inline>
			(function () {
				var promoPopup = document.getElementById('promo-popup');
				var promoClose = document.getElementById('promo-close');
				var promoCta = document.getElementById('promo-cta');
				var promoTrigger = document.getElementById('promo-trigger');

				function openPromo() {
					if (!promoPopup) return;
					promoPopup.classList.add('active');
					promoPopup.setAttribute('aria-hidden', 'false');
					if (promoTrigger) promoTrigger.setAttribute('aria-expanded', 'true');
				}

				function dismissPromo() {
					if (!promoPopup) return;
					promoPopup.classList.remove('active');
					promoPopup.setAttribute('aria-hidden', 'true');
					if (promoTrigger) promoTrigger.setAttribute('aria-expanded', 'false');
					sessionStorage.setItem('awcms-promo-dismissed', '1');
				}

				if (promoPopup && !sessionStorage.getItem('awcms-promo-dismissed')) {
					setTimeout(openPromo, 2000);
				}

				if (promoTrigger) promoTrigger.addEventListener('click', openPromo);
				if (promoClose) promoClose.addEventListener('click', dismissPromo);
				if (promoCta) promoCta.addEventListener('click', dismissPromo);
				if (promoPopup) {
					promoPopup.addEventListener('click', function (e) {
						if (e.target === promoPopup) dismissPromo();
					});
				}
				document.addEventListener('keydown', function (e) {
					if (e.key === 'Escape') dismissPromo();
				});
			})();
		</script>
	</>
)}

<style>
	.promo-float {
		position: fixed;
		bottom: clamp(1rem, 3vw, 2rem);
		left: clamp(1rem, 3vw, 2rem);
		z-index: 50;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		min-height: 3rem;
		padding: 0.75rem 1rem;
		border-radius: 999px;
		background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
		color: #fff;
		font-weight: 800;
		font-size: 0.875rem;
		border: none;
		cursor: pointer;
		box-shadow: 0 8px 24px rgba(99, 102, 241, 0.35), 0 16px 48px rgba(168, 85, 247, 0.2);
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		animation: promo-float-bounce 4s ease-in-out infinite;
	}

	.promo-float:hover {
		background: linear-gradient(135deg, #4f46e5 0%, #9333ea 100%);
		transform: translateY(-4px) scale(1.04);
		box-shadow: 0 12px 30px rgba(99, 102, 241, 0.45), 0 20px 50px rgba(168, 85, 247, 0.3);
	}

	.promo-float__icon {
		width: 1.2rem;
		height: 1.2rem;
		flex-shrink: 0;
	}

	.promo-overlay {
		position: fixed;
		inset: 0;
		z-index: 200;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(10, 14, 23, 0.72);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.3s ease;
	}

	.promo-overlay.active {
		opacity: 1;
		pointer-events: auto;
	}

	.promo-content {
		position: relative;
		width: min(92vw, 420px);
		background: var(--surface-main, #f8fafc);
		border: 1px solid var(--surface-border, rgba(14, 165, 233, 0.15));
		border-radius: 1.5rem;
		box-shadow: 0 32px 80px rgba(0, 0, 0, 0.28), 0 0 0 1px rgba(99, 102, 241, 0.12);
		overflow: hidden;
		transform: scale(0.94) translateY(12px);
		transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.promo-overlay.active .promo-content {
		transform: scale(1) translateY(0);
	}

	.promo-close-btn {
		position: absolute;
		top: 0.85rem;
		right: 1rem;
		z-index: 1;
		width: 2rem;
		height: 2rem;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(99, 102, 241, 0.08);
		border: 1px solid var(--surface-border, rgba(14, 165, 233, 0.15));
		border-radius: 50%;
		cursor: pointer;
		font-size: 1.2rem;
		color: var(--text-muted, #475569);
		transition: all 0.2s ease;
		line-height: 1;
	}

	.promo-close-btn:hover {
		background: rgba(239, 68, 68, 0.1);
		border-color: rgba(239, 68, 68, 0.3);
		color: #ef4444;
	}

	.promo-header {
		background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
		padding: 1rem 1.25rem 0.85rem;
	}

	.promo-badge {
		display: inline-block;
		padding: 0.3rem 0.85rem;
		background: rgba(255, 255, 255, 0.2);
		border: 1px solid rgba(255, 255, 255, 0.3);
		border-radius: 999px;
		color: #fff;
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.promo-body {
		padding: 1.25rem 1.5rem 1.5rem;
	}

	.promo-body h3 {
		margin: 0 0 0.5rem;
		font-size: 1.2rem;
		font-weight: 800;
		color: var(--text-main, #0f172a);
		line-height: 1.3;
	}

	.promo-body p {
		margin: 0 0 1rem;
		font-size: 0.9rem;
		color: var(--text-muted, #475569);
		line-height: 1.55;
	}

	.promo-pricing-box {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
		padding: 0.75rem 1rem;
		background: linear-gradient(135deg, rgba(99, 102, 241, 0.06), rgba(168, 85, 247, 0.04));
		border: 1px solid rgba(99, 102, 241, 0.15);
		border-radius: 0.75rem;
	}

	.promo-price-tag {
		font-size: 1rem;
		font-weight: 800;
		color: var(--text-main, #0f172a);
	}

	.promo-discount-tag {
		font-size: 0.8rem;
		font-weight: 700;
		color: #16a34a;
		background: rgba(22, 163, 74, 0.1);
		padding: 0.2rem 0.6rem;
		border-radius: 999px;
	}

	.promo-features-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.promo-features-list li {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.875rem;
		color: var(--text-main, #0f172a);
	}

	.promo-feature-icon {
		flex-shrink: 0;
		color: #16a34a;
	}

	.promo-cta-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		width: 100%;
		padding: 0.85rem 1.25rem;
		border-radius: 999px;
		background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
		color: #fff;
		font-weight: 800;
		font-size: 0.9rem;
		text-decoration: none;
		transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
		box-shadow: 0 8px 20px rgba(37, 211, 102, 0.28);
	}

	.promo-cta-btn:hover {
		background: linear-gradient(135deg, #128c7e 0%, #075e54 100%);
		color: #fff;
		transform: translateY(-2px);
		box-shadow: 0 12px 28px rgba(37, 211, 102, 0.4);
		text-shadow: none;
	}

	@keyframes promo-float-bounce {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-6px); }
	}

	@media (max-width: 640px) {
		.promo-float__label { display: none; }
		.promo-float {
			width: 3rem;
			height: 3rem;
			justify-content: center;
			padding: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.promo-float { animation: none !important; }
		.promo-float:hover { transform: none !important; }
		.promo-content { transition: none !important; }
	}
</style>
