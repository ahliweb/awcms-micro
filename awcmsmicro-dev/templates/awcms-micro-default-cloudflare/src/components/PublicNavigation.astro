---
import { getMenu } from "emdash";
import PublicNavigationItem from "./PublicNavigationItem.astro";

interface Props {
	name?: string;
}

const { name = "primary" } = Astro.props;
const menu = await getMenu(name);
---

{menu?.items.length ? (
	<nav class="awcms-public-nav" aria-label="Primary navigation">
		<ul class="awcms-public-nav__list">
			{menu.items.map((item) => (
				<PublicNavigationItem item={item} currentPath={Astro.url.pathname} level={0} />
			))}
		</ul>
	</nav>
) : null}

<style is:global>
	.awcms-public-nav {
		width: 100%;
	}

	.awcms-public-nav__list,
	.awcms-public-nav__submenu {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.awcms-public-nav__list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: flex-start;
	}

	.awcms-public-nav__item {
		position: relative;
	}

	.awcms-public-nav__link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.625rem 0.875rem;
		border-radius: 999px;
		border: 1px solid transparent;
		color: inherit;
		text-decoration: none;
		line-height: 1.2;
		transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
	}

	.awcms-public-nav__link:hover,
	.awcms-public-nav__link:focus-visible,
	.awcms-public-nav__link[aria-current="page"] {
		background: rgba(125, 211, 252, 0.14);
		border-color: rgba(125, 211, 252, 0.24);
		outline: none;
	}

	.awcms-public-nav__chevron {
		font-size: 0.8em;
		line-height: 1;
	}

	.awcms-public-nav__submenu {
		display: none;
		position: absolute;
		inset-block-start: calc(100% + 0.5rem);
		inset-inline-start: 0;
		min-width: 16rem;
		padding: 0.5rem;
		border: 1px solid rgba(125, 211, 252, 0.14);
		border-radius: 1rem;
		background: rgba(15, 23, 42, 0.96);
		box-shadow: 0 20px 45px rgba(15, 23, 42, 0.3);
		z-index: 20;
	}

	.awcms-public-nav__submenu .awcms-public-nav__submenu {
		inset-block-start: 0;
		inset-inline-start: calc(100% + 0.5rem);
	}

	.awcms-public-nav__item:hover > .awcms-public-nav__submenu,
	.awcms-public-nav__item:focus-within > .awcms-public-nav__submenu {
		display: block;
	}

	.awcms-public-nav__submenu .awcms-public-nav__link {
		display: flex;
		width: 100%;
		justify-content: space-between;
		border-radius: 0.75rem;
		padding: 0.55rem 0.75rem;
	}

	.awcms-public-nav__submenu .awcms-public-nav__item + .awcms-public-nav__item {
		margin-block-start: 0.25rem;
	}

	.awcms-public-nav__item.has-children > .awcms-public-nav__link {
		padding-inline-end: 0.7rem;
	}

	@media (max-width: 48rem) {
		.awcms-public-nav__list {
			flex-direction: column;
			align-items: stretch;
		}

		.awcms-public-nav__item {
			width: 100%;
		}

		.awcms-public-nav__link {
			width: 100%;
			justify-content: space-between;
		}

		.awcms-public-nav__submenu {
			position: static;
			display: block;
			min-width: 0;
			margin-block-start: 0.25rem;
			padding-inline-start: 0.5rem;
			box-shadow: none;
		}

		.awcms-public-nav__submenu .awcms-public-nav__submenu {
			margin-inline-start: 0.5rem;
		}
	}
</style>
