{
	"name": "@awcms-micro/core",
	"version": "0.0.1",
	"description": "AWCMS-Micro core compatibility layer containing schemas, normalizers, and i18n resolvers.",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"prepare": "node --run build",
		"prepublishOnly": "node --run build",
		"test": "vitest run",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"zod": "catalog:"
	},
	"peerDependencies": {
		"@cloudflare/kumo": "catalog:",
		"emdash": "workspace:*",
		"react": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@cloudflare/kumo": "catalog:",
		"@types/node": "24.10.13",
		"@types/react": "^19.2.14",
		"emdash": "workspace:*",
		"react": "19.2.4",
		"tsdown": "^0.20.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=22"
	}
}
