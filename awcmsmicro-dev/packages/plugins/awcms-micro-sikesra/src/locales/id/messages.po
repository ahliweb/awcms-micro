msgid "masked"
msgstr "dimasking"

msgctxt "awcms.adminCopy.publicNote"
msgid "Public note"
msgstr "Catatan publik"

msgctxt "awcms.adminCopy.publicNoteDescription"
msgid "The caveat explains why the aggregate is safe for public display."
msgstr "Catatan ini menjelaskan mengapa agregat aman untuk ditampilkan secara publik."

msgctxt "awcms.adminCopy.displayRule"
msgid "Display rule"
msgstr "Aturan tampil"

msgctxt "awcms.adminCopy.displayRuleDescription"
msgid "Masked buckets remain summarized but do not reveal entity-level details, matching the public-safe aggregate pattern."
msgstr "Bucket yang dimasking tetap diringkas tetapi tidak mengungkap detail tingkat entitas, sesuai pola agregat aman-publik."

msgctxt "awcms.adminCopy.auditEyebrow"
