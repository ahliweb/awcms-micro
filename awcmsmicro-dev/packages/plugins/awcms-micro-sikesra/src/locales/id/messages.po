msgstr "Surface pelaporan aman-publik yang hanya menampilkan hitungan kasar dan menghindari pengenal privat atau detail record sensitif."

msgctxt "awcms.adminCopy.categories"
msgid "Categories"
msgstr "Kategori"

msgctxt "awcms.adminCopy.categoriesHint"
msgid "Public-safe summary buckets"
msgstr "Bucket ringkasan aman-publik"

msgctxt "awcms.adminCopy.suppressed"
msgid "Suppressed"
msgstr "Disupresi"

msgctxt "awcms.adminCopy.suppressedHint"
msgid "Buckets hidden from public detail"
msgstr "Bucket yang disembunyikan dari detail publik"

msgctxt "awcms.adminCopy.visible"
msgid "Visible"
msgstr "Terlihat"

msgctxt "awcms.adminCopy.visibleHint"
msgid "Buckets safe to display openly"
msgstr "Bucket yang aman ditampilkan terbuka"

msgctxt "awcms.adminCopy.aggregateCategories"
msgid "Aggregate categories"
msgstr "Kategori agregat"

msgctxt "awcms.adminCopy.aggregateCategoriesDescription"
msgid "Counts are shown only when the category is not suppressed."
msgstr "Jumlah hanya ditampilkan ketika kategori tidak disupresi."

msgctxt "awcms.adminCopy.category"
msgid "Category"
msgstr "Kategori"

