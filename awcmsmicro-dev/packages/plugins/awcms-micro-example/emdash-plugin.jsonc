{
	"$schema": "https://emdashcms.com/schemas/emdash-plugin.schema.json",

	"slug": "awcms-micro-example",
	"version": "0.0.1",
	"license": "MIT",
	"publisher": "example.com", // Replace before publishing to a real registry.
	"author": { "name": "AWCMS-Micro" },
	"name": "AWCMS-Micro Example Plugin",
	"description": "Example EmDash-compatible plugin for AWCMS-Micro projects, packaged for standalone development and internal distribution.",
	"keywords": ["awcms-micro", "emdash", "plugin", "example", "tenant-ready"],

	"capabilities": [],
	"allowedHosts": [],
	"storage": {
		"audit": {
			"indexes": ["timestamp", "action", ["resource", "timestamp"]]
		}
	},

	"admin": {
		"pages": [{ "path": "/overview", "label": "Overview", "icon": "stack" }]
	}
}
