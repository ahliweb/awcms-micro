{
	"$schema": "https://emdashcms.com/schemas/emdash-plugin.schema.json",

	"slug": "awcms-micro-example",
	"version": "0.0.1",
	"license": "MIT",
	"publisher": "example.com", // Replace before any internal or public publish.
	"author": { "name": "AWCMS-Micro" },
	// Add `security` and `repo` when the final standalone package location is known.
	"name": "AWCMS-Micro Example Plugin",
	"description": "Access & audit demo plugin for AWCMS-Micro projects, demonstrating current EmDash plugin extension points without modifying EmDash core.",
	"keywords": ["awcms-micro", "emdash", "plugin", "example", "tenant-ready"],

	// Keep this trust contract aligned with the real runtime surface before release.
	"capabilities": ["content:read", "media:read", "media:write"],
	"allowedHosts": [],
	"storage": {
		"auditEvents": {
			"indexes": ["timestamp", "kind", "scope", ["scope", "timestamp"]]
		},
		"contentSnapshots": {
			"indexes": ["collection", "contentId", "timestamp", ["collection", "timestamp"]]
		}
	},

	"admin": {
		"pages": [
			{ "path": "/overview", "label": "Overview", "icon": "stack" },
			{ "path": "/audit", "label": "Audit", "icon": "list" },
			{ "path": "/access/permissions", "label": "Permissions", "icon": "lock" },
			{ "path": "/access/roles", "label": "Roles", "icon": "users" },
			{ "path": "/access/matrix", "label": "Role Matrix", "icon": "grid" },
			{ "path": "/access/preview", "label": "Access Preview", "icon": "eye" }
		],
		"widgets": [
			{ "id": "governance-status", "title": "Governance Status", "size": "half" },
			{ "id": "access-rights-health", "title": "Access Rights Health", "size": "half" }
		]
	}
}
