{
	"name": "@awcms-micro/plugin-example",
	"version": "0.0.1",
	"description": "AWCMS-Micro example plugin for EmDash-compatible projects",
	"type": "module",
	"main": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./admin": "./src/admin.ts"
	},
	"files": [
		"src",
		"module.manifest.json",
		"docs"
	],
	"keywords": [
		"awcms-micro",
		"emdash",
		"plugin",
		"example",
		"tenant-ready"
	],
