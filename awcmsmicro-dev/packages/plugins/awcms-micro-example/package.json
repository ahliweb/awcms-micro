		"typecheck": "tsgo --noEmit"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ahliweb/awcms-micro.git",
		"directory": "awcmsmicro-dev/packages/plugins/awcms-micro-example"
