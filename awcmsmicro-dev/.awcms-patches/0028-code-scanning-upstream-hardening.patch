+
+function stripHtmlTags(value: string) {
+	let output = "";
+	let inTag = false;
+	for (const char of value) {
+		if (char === "<") {
+			inTag = true;
+			output += " ";
+			continue;
+		}
+		if (char === ">") {
+			inTag = false;
+			continue;
+		}
+		if (!inTag) output += char;
+	}
+	return output;
+}
