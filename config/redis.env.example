# Optional Redis readiness profile for AWCMS-Micro (Issue #284).
#
# Redis is disabled by default. Copy this file to the ignored `.env.redis`
# only when the optional Redis layer is intentionally enabled:
#
#   cp config/redis.env.example .env.redis
#
# Never commit a real password or production REDIS_URL.

REDIS_ENABLED=true

# Bare-metal/systemd example. The optional Compose overlay replaces the host
# with the internal `redis` service and authenticates as the ACL user.
REDIS_URL=redis://awcms_app:change-me@127.0.0.1:6379/0

# Stable application-owned namespace. Derived products must use their own
# prefix so multiple applications cannot collide in one Redis deployment.
REDIS_KEY_PREFIX=awcms-micro

# Fail-fast behavior. Redis is an optimization, not a transactional dependency,
# so commands are not queued indefinitely while the server is disconnected.
REDIS_CONNECTION_TIMEOUT_MS=2000
REDIS_COMMAND_TIMEOUT_MS=1000
REDIS_MAX_RETRIES=3

# Generic cache-aside default. Each adopting module may choose a shorter TTL
# after documenting its staleness and invalidation policy.
REDIS_CACHE_DEFAULT_TTL_SEC=300

# Docker Compose overlay only. Store this value in the deployment secret
# manager and use a long URL-safe random value (A-Z, a-z, 0-9, `_`, `-`).
REDIS_PASSWORD=change-me-with-a-long-random-secret
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=noeviction
