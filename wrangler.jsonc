{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "awcms-micro",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-05-09",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "awcms-micro",
      "database_id": "local"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "awcms-micro-media"
    }
  ],
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ]
}
