{
  "$schema": "https://emdashcms.com/seed.schema.json",
  "version": "1",
  "meta": {
    "name": "AWCMS-Micro",
    "description": "An EmDash example repository aligned to the upstream blog Cloudflare template",
    "author": "Ahliweb"
  },
  "settings": {
    "title": "AWCMS-Micro",
    "tagline": "An EmDash example repository with a full-feature plugin"
  },
  "collections": [
    {
      "slug": "posts",
      "label": "Posts",
      "labelSingular": "Post",
      "supports": ["drafts", "revisions", "search", "seo"],
      "commentsEnabled": true,
      "fields": [
        { "slug": "title", "label": "Title", "type": "string", "required": true, "searchable": true },
        { "slug": "featured_image", "label": "Featured Image", "type": "image" },
        { "slug": "content", "label": "Content", "type": "portableText", "searchable": true },
        { "slug": "excerpt", "label": "Excerpt", "type": "text" }
      ]
    },
    {
      "slug": "pages",
      "label": "Pages",
      "labelSingular": "Page",
      "supports": ["drafts", "revisions", "search"],
      "fields": [
        { "slug": "title", "label": "Title", "type": "string", "required": true, "searchable": true },
        { "slug": "content", "label": "Content", "type": "portableText", "searchable": true }
      ]
    }
  ],
  "taxonomies": [
    {
      "name": "category",
      "label": "Categories",
      "labelSingular": "Category",
      "hierarchical": true,
      "collections": ["posts"],
      "terms": [
        { "slug": "announcements", "label": "Announcements" },
        { "slug": "plugin-development", "label": "Plugin Development" },
        { "slug": "deployment", "label": "Deployment" }
      ]
    },
    {
      "name": "tag",
      "label": "Tags",
      "labelSingular": "Tag",
      "hierarchical": false,
      "collections": ["posts"],
      "terms": [
        { "slug": "emdash", "label": "EmDash" },
        { "slug": "awcms-micro", "label": "AWCMS-Micro" },
        { "slug": "cloudflare", "label": "Cloudflare" },
        { "slug": "plugins", "label": "Plugins" }
      ]
    }
  ],
  "bylines": [
    {
      "id": "byline-ahlikoding",
      "slug": "ahlikoding-editorial",
      "displayName": "Ahlikoding Editorial"
    },
    {
      "id": "byline-guest",
      "slug": "guest-builder",
      "displayName": "Guest Builder",
      "isGuest": true
    }
  ],
  "menus": [
    {
      "name": "primary",
      "label": "Primary Navigation",
      "items": [
        { "type": "custom", "label": "Home", "url": "/" },
        { "type": "custom", "label": "About", "url": "/pages/about" },
        { "type": "custom", "label": "Posts", "url": "/posts" },
        { "type": "custom", "label": "Search", "url": "/search" }
      ]
    },
    {
      "name": "social",
      "label": "Social Links",
      "items": [
        { "type": "custom", "label": "GitHub", "url": "https://github.com/ahliweb/awcms-micro", "target": "_blank" },
        { "type": "custom", "label": "EmDash", "url": "https://emdashcms.com", "target": "_blank" }
      ]
    }
  ],
  "widgetAreas": [
    {
      "name": "sidebar",
      "label": "Sidebar",
      "description": "Appears on blog posts and pages",
      "widgets": [
        {
          "type": "component",
          "title": "Search",
          "componentId": "core:search"
        },
        {
          "type": "component",
          "title": "Categories",
          "componentId": "core:categories"
        },
        {
          "type": "component",
          "title": "Tags",
          "componentId": "core:tags"
        },
        {
          "type": "component",
          "title": "Recent Posts",
          "componentId": "core:recent-posts",
          "settings": { "count": 5, "showDate": true }
        },
        {
          "type": "component",
          "title": "Archives",
          "componentId": "core:archives",
          "settings": { "type": "monthly", "limit": 6 }
        }
      ]
    },
    {
      "name": "footer",
      "label": "Footer",
      "description": "Widgets displayed in the footer",
      "widgets": [
        {
          "type": "content",
          "title": "About",
          "content": [
            {
              "_type": "block",
              "_key": "footer-about-1",
              "style": "normal",
              "children": [{ "_type": "span", "_key": "footer-about-1-span", "text": "AWCMS-Micro is a standalone example repository that adopts EmDash directly and demonstrates how trusted plugins extend it." }]
            }
          ]
        }
      ]
    }
  ],
  "sections": [
    {
      "slug": "plugin-summary",
      "title": "Plugin Summary",
      "description": "Reusable section describing the example plugin",
      "keywords": ["plugin", "awcms", "emdash"],
      "source": "theme",
      "content": [
        {
          "_type": "block",
          "_key": "plugin-summary-1",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "plugin-summary-1-span",
              "text": "The bundled AWCMS-Micro plugin exercises trusted EmDash extension points including hooks, routes, dashboard widgets, admin pages, page metadata, page fragments, and Portable Text blocks."
            }
          ]
        }
      ]
    }
  ],
  "content": {
    "pages": [
      {
        "id": "about",
        "slug": "about",
        "status": "published",
        "data": {
          "title": "About",
          "content": [
            {
              "_type": "block",
              "_key": "about-1",
              "style": "normal",
              "children": [{ "_type": "span", "_key": "about-1-span", "text": "AWCMS-Micro is a standalone EmDash example repository. It does not host or wrap EmDash itself; it adopts the upstream patterns directly and stays focused on demonstrating how a site should extend EmDash through public APIs." }]
            },
            {
              "_type": "block",
              "_key": "about-2",
              "style": "normal",
              "children": [{ "_type": "span", "_key": "about-2-span", "text": "The site layer stays intentionally close to the official EmDash blog template, while the bundled plugin demonstrates trusted extension points such as admin pages, dashboard widgets, custom blocks, routes, hooks, and scheduled jobs." }]
            }
          ]
        }
      },
      {
        "id": "contact",
        "slug": "contact",
        "status": "published",
        "data": {
          "title": "Contact",
          "content": [
            {
              "_type": "block",
              "_key": "contact-1",
              "style": "normal",
              "children": [{ "_type": "span", "_key": "contact-1-span", "text": "Use the example forms and plugin routes as references when building contact flows on top of EmDash. This repository keeps the site itself simple so the extension points stay easy to inspect." }]
            }
          ]
        }
      }
    ],
    "posts": [
      {
        "id": "aligned-with-emdash",
        "slug": "aligned-with-emdash",
        "status": "published",
        "data": {
          "title": "Aligned with EmDash",
          "excerpt": "How AWCMS-Micro stays close to the upstream EmDash blog template while demonstrating trusted plugin extension points.",
          "featured_image": {
            "$media": {
              "url": "https://images.unsplash.com/photo-1515879218367-8466d910aaa4?w=1200&h=800&fit=crop",
              "alt": "Developer workstation with code on screen",
              "filename": "aligned-with-emdash.jpg"
            }
          },
          "content": [
            {
              "_type": "block",
              "_key": "post-1-1",
              "style": "normal",
              "children": [{ "_type": "span", "_key": "post-1-1-span", "text": "AWCMS-Micro is intentionally boring in the best way: it uses EmDash directly, follows the same public patterns as the upstream Cloudflare template, and keeps its customization surface small enough to inspect quickly." }]
            },
            {
              "_type": "block",
              "_key": "post-1-2",
              "style": "h2",
              "children": [{ "_type": "span", "_key": "post-1-2-span", "text": "What changes live here" }]
            },
            {
              "_type": "block",
              "_key": "post-1-3",
              "style": "normal",
              "children": [{ "_type": "span", "_key": "post-1-3-span", "text": "Branding, content, deployment names, and the bundled AWCMS-Micro plugin live in this repository. Core EmDash behavior does not." }]
            },
            {
              "_type": "awcms-callout",
              "_key": "post-1-callout",
              "title": "Plugin surface",
              "body": "The example plugin demonstrates lifecycle, content, media, comment, email, cron, page metadata, page fragments, admin pages, widgets, routes, settings, storage, and custom blocks.",
              "tone": "info"
            }
          ]
        },
        "bylines": [
          { "byline": "byline-ahlikoding" }
        ],
        "taxonomies": {
          "category": ["announcements"],
          "tag": ["emdash", "awcms-micro"]
        }
      },
      {
        "id": "trusted-plugin-features",
        "slug": "trusted-plugin-features",
        "status": "published",
        "data": {
          "title": "Trusted Plugin Features",
          "excerpt": "A tour of the trusted extension points used by the AWCMS-Micro example plugin.",
          "featured_image": {
            "$media": {
              "url": "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=1200&h=800&fit=crop",
              "alt": "Notebook, keyboard, and plugin planning materials",
              "filename": "trusted-plugin-features.jpg"
            }
          },
          "content": [
            {
              "_type": "block",
              "_key": "post-2-1",
              "style": "normal",
              "children": [{ "_type": "span", "_key": "post-2-1-span", "text": "Trusted plugins can do more than sandboxed plugins. They can contribute custom Portable Text blocks, render Astro components on the public site, and inject validated page fragments when you explicitly opt into those contributions in your layout." }]
            },
            {
              "_type": "awcms-video",
              "_key": "post-2-video",
              "id": "https://www.youtube.com/watch?v=dQw4w9WgXcQ",
              "title": "Example Video Embed"
            },
            {
              "_type": "block",
              "_key": "post-2-2",
              "style": "normal",
              "children": [{ "_type": "span", "_key": "post-2-2-span", "text": "This repository uses that trusted mode deliberately for the bundled example plugin so every first-class extension point is visible in one place." }]
            }
          ]
        },
        "bylines": [
          { "byline": "byline-ahlikoding" },
          { "byline": "byline-guest", "roleLabel": "Example collaborator" }
        ],
        "taxonomies": {
          "category": ["plugin-development"],
          "tag": ["emdash", "plugins", "cloudflare"]
        }
      }
    ]
  }
}
